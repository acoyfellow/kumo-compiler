---
import ExampleLayout from '../../../layouts/ExampleLayout.astro';
import SyntaxCode from '../../../components/SyntaxCode.astro';
const install='npm install https://kumo-compiler.coey.dev/packages/kumo-solid-0.0.1.tgz';
---
<ExampleLayout title="Solid Button and Field" framework="solid" install={install} download="/examples/downloads/kumo-solid-example.zip" library="/libraries/solid/"><h2>App.jsx</h2><SyntaxCode lang="jsx" label="App.jsx" code={`import { createSignal } from 'solid-js';
import { Button, Field } from '@acoyfellow/kumo-solid';
import '@acoyfellow/kumo-solid/styles.css';

export default function App() {
  const [clicks, setClicks] = createSignal(0);
  const [project, setProject] = createSignal('Workers');
  return <>
    <Button onClick={() => setClicks(x => x + 1)}>Clicked {clicks()}</Button>
    <Button disabled>Disabled</Button>
    <Field id="project" label="Project" description="Rendered by Kumo" required value={project()} onInput={e => setProject(e.currentTarget.value)} />
    <p>Model: {project()}</p>
  </>;
}`} /><p>The archive includes Solid’s Vite plugin and a production tarball dependency.</p></ExampleLayout>
