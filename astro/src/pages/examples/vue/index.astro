---
import ExampleLayout from '../../../layouts/ExampleLayout.astro';
import SyntaxCode from '../../../components/SyntaxCode.astro';
const install='npm install https://kumo-compiler.coey.dev/packages/kumo-vue-0.0.1.tgz';
---
<ExampleLayout title="Vue Button and Field" framework="vue" install={install} download="/examples/downloads/kumo-vue-example.zip" library="/libraries/vue/"><h2>App.vue</h2><SyntaxCode lang="vue" label="App.vue" code={`<script setup>
import { ref } from 'vue';
import { Button, Field } from '@acoyfellow/kumo-vue';
import '@acoyfellow/kumo-vue/styles.css';
const clicks = ref(0);
const project = ref('Workers');
</script>

<template>
  <Button @click="clicks++">Clicked {{ clicks }}</Button>
  <Button disabled>Disabled</Button>
  <Field id="project" label="Project" description="Rendered by Kumo" required v-model="project" />
  <p>Model: {{ project }}</p>
</template>`} /><p>The archive includes <code>package.json</code>, Vite configuration, HTML, and this component.</p></ExampleLayout>
