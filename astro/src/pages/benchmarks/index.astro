---
import Layout from '../../layouts/Layout.astro';
import catalog from '../../../../benchmarks/catalog.json';
---
<Layout title="Benchmark catalog · Kumo">
  <h1>Component benchmark catalog</h1>
  <p>Measured evidence tied to benchmark artifacts and the source commit.</p>
  <div class="grid">{catalog.components.map(component => <article><span>{component.status}</span><h2><a href={`/benchmarks/components/${component.id}/`}>{component.name}</a></h2><p>{component.frameworks.length} framework runtimes</p></article>)}</div>
  <style>.grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-top:30px}article{background:#fff;border:1px solid #d1d5db;border-radius:12px;padding:18px}span{color:#15803d;font-weight:700}a{color:#2563eb}p{color:#64748b}</style>
</Layout>
