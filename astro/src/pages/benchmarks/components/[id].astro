---
import Layout from '../../../layouts/Layout.astro';
import catalog from '../../../../../benchmarks/catalog.json';
export function getStaticPaths() {
  return catalog.components.map(component => ({params:{id:component.id},props:{component}}));
}
const {component}=Astro.props;
---
<Layout title={`${component.name} benchmark · Kumo`}>
  <p><a href="/benchmarks/">← benchmark catalog</a></p>
  <h1>{component.name} benchmark</h1>
  <p>Status: <strong>{component.status}</strong> · {component.frameworks.length} framework runtimes</p>
  <dl><dt>Frameworks</dt><dd>{component.frameworks.join(', ')}</dd><dt>Source commit</dt><dd><code>{catalog.source.commit}</code></dd></dl>
  <p><a href={`/components/${component.id}/`}>Open the {component.name} component proof</a></p>
  <style>a{color:#2563eb}strong{color:#15803d}dl{background:#fff;border:1px solid #d1d5db;border-radius:12px;padding:20px}dt{font-weight:800;margin-top:12px}dd{margin:4px 0;color:#64748b}</style>
</Layout>
