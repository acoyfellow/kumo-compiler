---
import Layout from '../../../layouts/Layout.astro';
import LibraryGallery from '../../../components/LibraryGallery.astro';
import artifacts from '../../../../../library-artifacts/manifest.json';
const artifact = artifacts.packages.find(entry => entry.framework === 'solid');
if (!artifact) throw new Error('missing Solid library artifact');
---
<Layout title="Kumo Solid component library"><LibraryGallery framework="solid" packageName={artifact.package} sha256={artifact.sha256} receiptDigest={artifact.receiptDigest} /></Layout>
