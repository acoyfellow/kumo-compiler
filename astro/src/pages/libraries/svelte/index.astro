---
import Layout from '../../../layouts/Layout.astro';
import LibraryGallery from '../../../components/LibraryGallery.astro';
import artifacts from '../../../../../library-artifacts/manifest.json';
const artifact = artifacts.packages.find(entry => entry.framework === 'svelte');
if (!artifact) throw new Error('missing Svelte library artifact');
---
<Layout title="Kumo Svelte component library"><LibraryGallery framework="svelte" packageName={artifact.package} sha256={artifact.sha256} receiptDigest={artifact.receiptDigest} /></Layout>
