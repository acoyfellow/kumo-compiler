---
import Layout from '../../../layouts/Layout.astro';
import LibraryGallery from '../../../components/LibraryGallery.astro';
import artifacts from '../../../../../library-artifacts/manifest.json';
const artifact = artifacts.packages.find(entry => entry.framework === 'vue');
if (!artifact) throw new Error('missing Vue library artifact');
---
<Layout title="Kumo Vue component library"><LibraryGallery framework="vue" packageName={artifact.package} sha256={artifact.sha256} receiptDigest={artifact.receiptDigest} /></Layout>
