ent:space-between;gap:20px;margin-top:52px;padding:24px;border:1px solid #d8dde5;border-radius:11px;background:#fff}.libraries p{margin:8px 0 0;color:#64748b}.libraries nav{display:flex;flex-wrap:wrap;gap:8px}.libraries nav a{padding:10px 14px;border-radius:7px;background:#111827;color:white;font-weight:750;text-decoration:none}@media(max-width:720px){.heading,.libraries{display:block}.heading>p{margin-top:9px}.grid{grid-template-columns:1fr}.libraries nav{margin-top:18px}.stats{grid-template-columns:repeat(2,minmax(0,1fr))}.gate-stats{grid-template-columns:repeat(3,minmax(0,1fr))}}@media(max-width:420px){.gate-stats{grid-template-columns:repeat(2,minmax(0,1fr))}}
</style>
