---
import DocsLayout from '../../../../layouts/DocsLayout.astro';
import language from '../../../../../../benchmarks/shootout/languages/latest.json';
import baseline from '../../../../../../benchmarks/compilers/typescript-baseline.json';
import productBaseline from '../../../../../../proof/shootout/baseline/baseline.json';
import architecture from '../../../../../../proof/shootout/architectures/matrix.json';

const fmtMs = value => `${Number(value).toFixed(2)} ms`;
const fmtBytes = value => value >= 1_000_000 ? `${(value / 1_000_000).toFixed(2)} MB` : value >= 1_000 ? `${(value / 1_000).toFixed(1)} KB` : `${value} B`;
const engineLinks = { typescript: '/typescript/', go: '/go/', rust: '/rust/', zig: '/zig/' };
const engineNames = { typescript: 'TypeScript', go: 'Go', rust: 'Rust', zig: 'Zig' };
const engineCards = language.results.map(result => ({
  ...result,
  name: engineNames[result.language],
  href: engineLinks[result.language],
  scope: 'Planner protocol only',
}));
const architectureCards = architecture.dimensions.candidates.map(candidate => {
  const cells = architecture.receipts.filter(cell => cell.candidate === candidate);
  const statuses = cells.reduce((all, cell) => {
    for (const status of Object.values(cell.gates)) all[status] = (all[status] || 0) + 1;
    return all;
  }, { passed: 0, failed: 0, blocked: 0, 'not-run': 0 });
  const metadata = {
    'internal-ts': { name: 'Internal compiler', href: '/typescript/', mode: 'Control evidence' },
    mitosis: { name: 'Mitosis', href: '/mitosis/', mode: 'Generated candidate' },
    'shared-core-native': { name: 'Shared core + native', href: '/shared-core/', mode: 'Native-view candidate' },
    'minimal-hybrid': { name: 'Minimal hybrid', href: '/output-architecture/', mode: 'Prepared candidate' },
  }[candidate];
  const receiptStatuses = cells.reduce((all, cell) => {
    all[cell.status] = (all[cell.status] || 0) + 1;
    return all;
  }, {});
  const eligible = cells.every(cell => cell.eligible);
  return { candidate, cells: cells.length, statuses, receiptStatuses, eligible, ...metadata };
});
---
<DocsLayout title="Compiler results" description="Receipt-derived engine and output-architecture results for the Kumo compiler study.">
  <header class="intro">
    <p class="eyebrow">Kumo compiler study</p>
    <h1>Compiler results at a glance</h1>
    <p>Engine language and output architecture are separate questions. These cards show the selected receipt data; open any card for its full results and limitations.</p>
  </header>

  <section class="results" aria-labelledby="engine-title">
    <div class="heading"><div><p class="kicker">Axis A · Engine language</p><h2 id="engine-title">Compiler engines</h2></div><p>Same normalized Button + Select planner fixture. Planner correctness passed for all four; product gates, CPU, and peak RSS remain blocked. <a href="/engine-language/">Full engine comparison →</a></p></div>
    <div class="grid engines">
      {engineCards.map(card => <a class="card" href={card.href}>
        <div class="card-top"><span class="status">Planner {card.correctness}</span><span class="scope">{card.scope}</span></div>
        <h3>{card.name}</h3>
        <dl class="stats">
          <div><dt>Median</dt><dd>{fmtMs(card.performance.summary.medianWallMs)}</dd></div>
          <div><dt>p95</dt><dd>{fmtMs(card.performance.summary.p95WallMs)}</dd></div>
          <div><dt>Distribution</dt><dd>{fmtBytes(card.distribution.binaryBytes)}</dd></div>
          <div><dt>Raw output</dt><dd>{card.rawOutput.files} files · {fmtBytes(card.rawOutput.bytes)}</dd></div>
        </dl>
        {card.language === 'typescript' && <p class="baseline"><strong>Separate full-product control:</strong> {productBaseline.authority.coverage} authority coverage · {baseline.output.files} generated files · {fmtBytes(baseline.output.bytes)}</p>}
        <b>Full {card.name} results →</b>
      </a>)}
    </div>
  </section>

  <section class="results" aria-labelledby="architecture-title">
    <div class="axis-divider" aria-hidden="true"></div>
    <div class="heading"><div><p class="kicker">Axis B · Output architecture</p><h2 id="architecture-title">Output architectures</h2></div><p>Exact {architecture.cellCount}-cell Button + Select matrix. Critical evidence is incomplete, so weights were not applied and there is no winner. <a href="/output-architecture/">Full architecture comparison →</a></p></div>
    <div class="grid architectures">
      {architectureCards.map(card => <a class="card" href={card.href}>
        <div class="card-top"><span class="status pending">{card.eligible ? 'eligible' : 'not eligible'}</span><span class="scope">{card.mode}</span></div>
        <h3>{card.name}</h3>
        <dl class="stats gate-stats">
          <div><dt>Cells</dt><dd>{card.cells}</dd></div>
          <div><dt>Cell status</dt><dd>{card.receiptStatuses.failed ? `${card.receiptStatuses.failed} failed` : `${card.receiptStatuses.blocked ?? 0} blocked`}</dd></div>
          <div><dt>Passed</dt><dd>{card.statuses.passed}</dd></div>
          <div><dt>Failed</dt><dd>{card.statuses.failed}</dd></div>
          <div><dt>Blocked</dt><dd>{card.statuses.blocked}</dd></div>
          <div><dt>Not run</dt><dd>{card.statuses['not-run']}</dd></div>
        </dl>
        <b>Full {card.name} results →</b>
      </a>)}
    </div>
    <p class="matrix-total">Matrix total: <strong>{architecture.gateCounts.passed} passed</strong> · <strong>{architecture.gateCounts.failed} failed</strong> · <strong>{architecture.gateCounts.blocked} blocked</strong> · <strong>{architecture.gateCounts['not-run']} not-run</strong>.</p>
  </section>

  <section class="libraries"><div><p class="kicker">Use the output</p><h2>Framework libraries</h2><p>See and install the current Button + Field libraries.</p></div><nav aria-label="Framework libraries"><a href="/libraries/vue/">Vue →</a><a href="/libraries/svelte/">Svelte →</a><a href="/libraries/solid/">Solid →</a></nav></section>
</DocsLayout>
<style>
