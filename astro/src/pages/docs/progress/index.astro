---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import progress from '../../../../../proof/progress/latest.json';
const icon={passed:'✓','in-progress':'→','not-run':'○',failed:'×',blocked:'!'};
---
<DocsLayout title="Completion progress" description="Receipt-derived Kumo library completion progress."><p class="eyebrow">Live project status</p><h1>Kumo completion progress</h1><p class="lede">This page is generated from machine receipts. Current phase: <strong>{progress.currentPhase}</strong>.</p><div class="phases">{progress.phases.map(phase=><article><div class="row"><span class={`state ${phase.status}`}>{icon[phase.status]??'·'}</span><div><h2>{phase.label}</h2><p>{phase.done} / {phase.total}</p></div></div><progress value={phase.done} max={phase.total}>{phase.done}/{phase.total}</progress></article>)}</div><h2>Exact scope</h2><ul><li>{progress.scope.executable} executable components must pass every gate.</li><li>{progress.scope.upstreamBlocked.join(' and ')} remain upstream-export blocked.</li><li>{progress.scope.supplemental.join(' and ')} are supplemental, not executable.</li></ul><p><a href="/docs/evidence/compiler-results/">Compiler evidence →</a></p></DocsLayout>
<style>.eyebrow{color:#b45309;font-size:13px;font-weight:850;letter-spacing:.09em;text-transform:uppercase}.phases{display:grid;gap:12px;margin-top:30px}.phases article{padding:18px;border:1px solid #d8dde5;border-radius:10px;background:#fff}.row{display:flex;align-items:center;gap:14px}.row h2{margin:0!important;font-size:19px!important}.row p{margin:4px 0 0!important;color:#64748b}.state{display:grid;width:34px;height:34px;place-items:center;border-radius:50%;font-weight:900}.state.passed{background:#dcfce7;color:#166534}.state.in-progress{background:#dbeafe;color:#1d4ed8}.state.not-run{background:#e5e7eb;color:#475569}progress{width:100%;height:10px;margin-top:14px;accent-color:#075fc7}</style>
