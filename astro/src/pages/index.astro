---
import Layout from '../layouts/Layout.astro';
import catalog from '../../../benchmarks/catalog.json';
const groups=[['Core',['select','button','dialog','popover','checkbox','switch']],['Navigation',['tabs','menu-bar','sidebar','breadcrumbs','table-of-contents']],['Forms',['field','input','input-group','input-area','sensitive-input','clipboard-text']],['Data / Presentational',['badge','banner','surface','layer-card','grid','grid-item','loader','meter','empty','label','link','text','cloudflare-logo','code','table']],['Selection / Command / Date',['radio','autocomplete','combobox','command-palette','date-picker','date-range-picker','dropdown-menu','toasty','pagination']]];
const byId=Object.fromEntries(catalog.components.map(c=>[c.id,c]));
const frameworks=[['react','R'],['vue','V'],['svelte','Sv'],['solid','So']];
const ms=value=>`${Number(value).toLocaleString(undefined,{maximumFractionDigits:1})} ms`;
const kb=value=>`${(Number(value)/1024).toLocaleString(undefined,{maximumFractionDigits:1})} kB`;
---
<Layout title="Kumo compiler"><header class="hero"><p class="eyebrow">Kumo 2.5.2</p><h1>Kumo compiler catalog</h1><p>Real runtime proofs and measured output for React, Vue, Svelte, and Solid.</p></header>{groups.map(([family,ids])=><section class="family"><h2>{family}</h2><div class="table-wrap"><table><thead><tr><th>Component</th><th>Build time</th><th>JavaScript bundle</th></tr></thead><tbody>{ids.map(id=>{const c=byId[id];return <tr><td><a href={`/${id}/`}>{c?.name ?? id}</a></td><td><div class="metrics">{frameworks.map(([key,label])=><span><b>{label}</b> {ms(c.metrics.buildMs[key])}</span>)}</div></td><td><div class="metrics">{frameworks.map(([key,label])=><span><b>{label}</b> {kb(c.metrics.bundleBytes[key])}</span>)}</div></td></tr>})}</tbody></table></div></section>)}<style>.hero{max-width:760px}.eyebrow{margin:0 0 8px;color:var(--text-color-muted,#64748b);font-weight:700;text-transform:uppercase;letter-spacing:.08em;font-size:12px}.hero h1{font-size:44px;letter-spacing:-.04em;margin:0 0 10px}.hero>p:last-child{color:var(--text-color-muted,#64748b);font-size:18px}.family{margin-top:42px}.family h2{font-size:20px;margin:0 0 12px}.table-wrap{overflow:auto;border:1px solid var(--color-border,#d1d5db);border-radius:12px;background:var(--color-surface,#fff)}table{width:100%;border-collapse:collapse}th,td{padding:14px 16px;border-bottom:1px solid var(--color-border,#e5e7eb);text-align:left;vertical-align:top}th{background:var(--color-surface-secondary,#f8fafc);font-size:13px}tbody tr:last-child td{border-bottom:0}td>a{font-weight:750;color:var(--text-color-link,#0759b6);text-decoration:none}.metrics{display:grid;grid-template-columns:repeat(2,minmax(128px,1fr));gap:6px 14px;white-space:nowrap;font-variant-numeric:tabular-nums}.metrics span{color:var(--text-color-muted,#64748b)}.metrics b{display:inline-block;min-width:22px;color:var(--text-color-surface,#111827)}@media(max-width:760px){.metrics{grid-template-columns:1fr}.hero h1{font-size:36px}}</style></Layout>
