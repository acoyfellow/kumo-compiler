---
import Layout from '../layouts/Layout.astro';
import SyntaxCode from '../components/SyntaxCode.astro';
const snippets={
  svelte:`<script>\n  import { Button, Field } from '@cloudflare/kumo-svelte';\n  import '@cloudflare/kumo-svelte/styles.css';\n  let project = $state('Workers');\n</script>\n\n<Button>Deploy project</Button>\n<Field id="project" label="Project" bind:value={project} />`,
  vue:`<script setup>\nimport { ref } from 'vue';\nimport { Button, Field } from '@cloudflare/kumo-vue';\nimport '@cloudflare/kumo-vue/styles.css';\nconst project = ref('Workers');\n</script>\n\n<template>\n  <Button>Deploy project</Button>\n  <Field id="project" label="Project" v-model="project" />\n</template>`,
  solid:`import { createSignal } from 'solid-js';\nimport { Button, Field } from '@cloudflare/kumo-solid';\nimport '@cloudflare/kumo-solid/styles.css';\n\nexport default function App() {\n  const [project, setProject] = createSignal('Workers');\n  return <>\n    <Button>Deploy project</Button>\n    <Field id="project" label="Project" value={project()} onInput={e => setProject(e.currentTarget.value)} />\n  </>;\n}`
};
---
<Layout title="Kumo framework libraries" description="Install Button and Field for Vue, Svelte, and Solid—framework-native libraries derived from Cloudflare Kumo.">
<section class="hero"><div class="hero-copy"><p class="eyebrow">Kumo outside React</p><h1>One component language.<br><span>Three native frameworks.</span></h1><p class="lede">Install Button and Field for Vue, Svelte, or Solid. Real packages, complete examples, SSR and browser proof.</p><div class="actions"><a class="primary" href="/docs/tutorials/first-library/">Start building</a><a href="/examples/">Open examples</a></div><p class="scope"><strong>Supported now:</strong> Button + Field. <a href="/docs/explanation/evidence/">How readiness is proven →</a></p></div><div class="snippet"><div class="tabs" role="tablist" aria-label="Framework code"><button role="tab" aria-selected="true" aria-controls="snippet-svelte" id="tab-svelte" data-tab="svelte">Svelte</button><button role="tab" aria-selected="false" aria-controls="snippet-vue" id="tab-vue" data-tab="vue">Vue</button><button role="tab" aria-selected="false" aria-controls="snippet-solid" id="tab-solid" data-tab="solid">Solid</button></div><div id="snippet-svelte" role="tabpanel" aria-labelledby="tab-svelte" data-panel="svelte"><SyntaxCode code={snippets.svelte} lang="svelte" label="App.svelte" /></div><div id="snippet-vue" role="tabpanel" aria-labelledby="tab-vue" data-panel="vue" hidden><SyntaxCode code={snippets.vue} lang="vue" label="App.vue" /></div><div id="snippet-solid" role="tabpanel" aria-labelledby="tab-solid" data-panel="solid" hidden><SyntaxCode code={snippets.solid} lang="tsx" label="App.tsx" /></div></div></section>
<section class="frameworks" aria-labelledby="framework-title"><div><p class="eyebrow">Pick your framework</p><h2 id="framework-title">Package-native from the first import.</h2></div><div class="framework-grid"><a href="/libraries/svelte/"><strong>Svelte</strong><span>Runes and bind:value</span></a><a href="/libraries/vue/"><strong>Vue</strong><span>Composition API and v-model</span></a><a href="/libraries/solid/"><strong>Solid</strong><span>Signals and JSX</span></a></div></section>
<section class="proof"><p>Want the compiler study?</p><a href="/docs/evidence/compiler-results/">Explore engine and architecture results →</a></section>
<script>const tabs=[...document.querySelectorAll('[data-tab]')],panels=[...document.querySelectorAll('[data-panel]')];const select=name=>{tabs.forEach(tab=>{const active=tab.dataset.tab===name;tab.setAttribute('aria-selected',String(active));tab.tabIndex=active?0:-1});panels.forEach(panel=>panel.hidden=panel.dataset.panel!==name)};tabs.forEach((tab,index)=>{tab.addEventListener('click',()=>select(tab.dataset.tab));tab.addEventListener('keydown',event=>{if(!['ArrowLeft','ArrowRight'].includes(event.key))return;event.preventDefault();const next=(index+(event.key==='ArrowRight'?1:-1)+tabs.length)%tabs.length;select(tabs[next].dataset.tab);tabs[next].focus()})});</script>
</Layout>
<style>.hero{display:grid;grid-template-columns:minmax(0,.9fr) minmax(480px,1.1fr);align-items:center;gap:clamp(34px,7vw,90px);min-height:calc(100dvh - 170px);padding:48px 0 70px}.eyebrow{margin:0 0 12px;color:#b45309;font-size:12px;font-weight:850;letter-spacing:.1em;text-transform:uppercase}.hero h1{margin:0;font-size:clamp(48px,7vw,86px);line-height:.95;letter-spacing:-.055em}.hero h1 span{color:#64748b}.lede{max-width:610px;margin:25px 0;color:#475569;font-size:clamp(19px,2vw,23px);line-height:1.55}.actions{display:flex;flex-wrap:wrap;gap:10px;margin:28px 0}.actions a{display:inline-flex;align-items:center;min-height:48px;padding:11px 16px;border:1px solid #94a3b8;border-radius:8px;color:#111827;font-weight:800;text-decoration:none}.actions .primary{border-color:#075fc7;background:#075fc7;color:#fff}.scope{color:#64748b;font-size:14px}.scope a{color:#075fc7}.snippet{min-width:0;border:1px solid #d8dde5;border-radius:14px;background:#fff;box-shadow:0 24px 70px #0f172a14;overflow:hidden}.snippet :global(.syntax){margin:0;border:0;border-radius:0}.tabs{display:flex;gap:4px;padding:8px;border-bottom:1px solid #d8dde5;background:#f8fafc}.tabs button{min-width:80px;min-height:44px;border:0;border-radius:7px;background:transparent;color:#475569;font-weight:800}.tabs button[aria-selected=true]{background:#111827;color:#fff}.frameworks{padding:60px 0;border-top:1px solid #d8dde5}.frameworks h2{max-width:620px;margin:0;font-size:clamp(32px,4vw,48px);letter-spacing:-.04em}.framework-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px;margin-top:28px}.framework-grid a{display:block;padding:22px;border:1px solid #d8dde5;border-radius:11px;background:#fff;color:#111827;text-decoration:none}.framework-grid strong{display:block;font-size:24px}.framework-grid span{display:block;margin-top:6px;color:#64748b}.proof{display:flex;align-items:center;justify-content:space-between;gap:20px;padding:26px;border-radius:12px;background:#111827;color:#fff}.proof p{margin:0;font-size:20px;font-weight:800}.proof a{display:inline-flex;align-items:center;min-height:44px;color:#93c5fd;font-weight:800}@media(max-width:940px){.hero{grid-template-columns:1fr;min-height:auto}.snippet{max-width:760px}.framework-grid{grid-template-columns:1fr}}@media(max-width:520px){.hero{padding-top:38px}.hero h1{font-size:48px}.tabs button{min-width:0;flex:1}.proof{display:block}.proof a{margin-top:8px}}
</style>
