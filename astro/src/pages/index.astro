---
import Layout from '../layouts/Layout.astro';
import FrameworkIcon from '../components/FrameworkIcon.astro';
import catalog from '../../../benchmarks/catalog.json';
import { catalogEvidence, frameworks } from '../../../scripts/catalog-evidence.mjs';
const groups = [
  ['Core', ['select','button','dialog','popover','checkbox','switch']],
  ['Navigation', ['tabs','menu-bar','sidebar','breadcrumbs','table-of-contents']],
  ['Forms', ['field','input','input-group','input-area','sensitive-input','clipboard-text']],
  ['Data & display', ['badge','banner','surface','layer-card','grid','grid-item','loader','meter','empty','label','link','text','cloudflare-logo','code','table']],
  ['Selection, command & date', ['radio','autocomplete','combobox','command-palette','date-picker','date-range-picker','dropdown-menu','toasty','pagination']]
];
const { components, nativeVue, legacyVue, totals, frameworkStatus, statusCounts } = catalogEvidence(catalog);
const byId = Object.fromEntries(components.map(component => [component.id, component]));
const names = { react: 'React', vue: 'Vue', svelte: 'Svelte', solid: 'Solid' };
const ms = value => Number(value).toLocaleString(undefined, { maximumFractionDigits: 1 });
const kb = value => (Number(value) / 1024).toLocaleString(undefined, { maximumFractionDigits: 1 });
const statusFor = (framework, id) => frameworkStatus[framework][id].status;
---
<Layout title="Kumo compiler evidence catalog">
  <header class="hero">
    <p class="eyebrow">Kumo 2.5.2 <span>·</span> Evidence catalog</p>
    <h1>One component language.<br><em>Four native surfaces.</em></h1>
    <p class="lede">The compiler turns Kumo’s canonical components into a shared semantic model, then emits and verifies native React, Vue, Svelte, and Solid runtimes.</p>
    <div class="hero-frameworks" aria-label="Supported frameworks">{frameworks.map(framework => <span><FrameworkIcon framework={framework} size={28}/><span>{names[framework]}</span></span>)}</div>
  </header>
  <section class="status-panel" aria-labelledby="status-title">
    <div class="section-heading"><div><p class="kicker">Current result</p><h2 id="status-title">Receipt-derived status</h2></div><div class="score"><strong>{components.length * frameworks.length}</strong><span>verified surfaces</span></div></div>
    <div class="status-grid">{frameworks.map(framework => <article><FrameworkIcon framework={framework} size={30}/><div><strong>{names[framework]}</strong><span>{Object.entries(statusCounts[framework]).map(entry => entry[1] + ' ' + entry[0]).join(' · ')}</span></div><span class="status-dot" aria-hidden="true"></span></article>)}</div>
    <details><summary>Evidence limitations</summary><p><strong>{nativeVue.length}/{components.length} Vue outputs are framework-native.</strong> The other <strong>{legacyVue.length}/{components.length}</strong> are legacy outputs. React evidence is credited only when bound to an exact source and package revision. Pixel equality alone does not prove accessibility, behavioral completeness, source quality, or equivalent runtime internals.</p></details>
  </section>
  <section aria-labelledby="measure-title"><div class="section-heading"><div><p class="kicker">Measured fixtures</p><h2 id="measure-title">Build and bundle overview</h2></div></div><div class="totals">{frameworks.map(framework => <article><FrameworkIcon framework={framework} size={28}/><strong>{names[framework]}</strong><dl><div><dt>Mean build</dt><dd>{ms(totals[framework].meanBuildMs)} <small>ms</small></dd></div><div><dt>Catalog JS</dt><dd>{kb(totals[framework].bundleBytes)} <small>kB</small></dd></div></dl></article>)}</div></section>
  <section class="method" aria-labelledby="proof-title"><div><p class="kicker">Method</p><h2 id="proof-title">What “verified” means</h2></div><p>Every runtime route builds. Proofs inspect server markup, semantic and ARIA state, hydration, interaction tokens, screenshots, and asset provenance. Measurements describe checked-in fixtures at <code>{catalog.source.commit}</code>—not application-wide performance forecasts.</p></section>
  <section class="catalog" aria-labelledby="catalog-title"><div class="section-heading catalog-heading"><div><p class="kicker">Component catalog</p><h2 id="catalog-title">Compare all {components.length}</h2></div><p>Each framework cell shows receipt status, build time, and JavaScript size.</p></div>
    {groups.map(group => <section class="family"><h3>{group[0]}<span>{group[1].length}</span></h3><div class="matrix" role="table" aria-label={group[0] + ' component evidence'}>
      <div class="matrix-head" role="row"><div role="columnheader">Component</div>{frameworks.map(framework => <div role="columnheader" aria-label={names[framework]}><FrameworkIcon framework={framework} size={25}/><span>{names[framework]}</span></div>)}</div>
      {group[1].map(id => { const component = byId[id]; return <div class="matrix-row" role="row"><div class="component-cell" role="rowheader"><a href={'/components/' + id + '/'}>{component.name}</a><span><a href={'/components/' + id + '/'}>Compare</a><i aria-hidden="true">↗</i></span></div>{frameworks.map(framework => <div class="framework-cell" role="cell"><div class="mobile-framework"><FrameworkIcon framework={framework} size={19}/><span>{names[framework]}</span></div><a class="receipt" href={'/receipts/' + id + '.' + framework + '.json'}><span class="status-dot" aria-hidden="true"></span>{statusFor(framework,id)}</a><span class="measure"><b>{ms(component.metrics.buildMs[framework])}</b> ms</span><span class="measure"><b>{kb(component.metrics.bundleBytes[framework])}</b> kB</span></div>)}</div> })}
    </div></section>)}
  </section>
</Layout>
<style>
.hero{max-width:900px;padding:34px 0 12px}.eyebrow,.kicker{margin:0 0 10px;color:#64748b;font-size:12px;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.eyebrow span{color:#f48120}.hero h1{margin:0;font-size:clamp(42px,6vw,72px);line-height:.98;letter-spacing:-.055em}.hero h1 em{color:#5264ae;font-style:normal}.lede{max-width:760px;margin:24px 0 20px;color:#556070;font-size:18px;line-height:1.65}.hero-frameworks{display:flex;flex-wrap:wrap;gap:10px}.hero-frameworks>span{display:flex;align-items:center;gap:8px;padding:8px 12px;border:1px solid #dfe3e8;border-radius:999px;background:#fff;font-size:13px;font-weight:750}.section-heading{display:flex;align-items:end;justify-content:space-between;gap:24px;margin-bottom:18px}.section-heading h2,.method h2{margin:0;font-size:clamp(24px,3vw,34px);letter-spacing:-.03em}.status-panel{padding:24px;border:1px solid #d9dee5;border-radius:18px;background:linear-gradient(145deg,#fff 40%,#f4f7ff);box-shadow:0 12px 36px rgb(15 23 42 / 6%)}.score{display:flex;align-items:baseline;gap:9px}.score strong{font-size:34px;letter-spacing:-.04em}.score span{color:#64748b;font-size:13px}.status-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}.status-grid article{display:flex;align-items:center;gap:11px;min-width:0;padding:13px;border:1px solid #e1e5ea;border-radius:12px;background:#fff}.status-grid article>div{display:grid;min-width:0}.status-grid strong{font-size:14px}.status-grid article span:not(.status-dot){overflow:hidden;color:#64748b;font-size:11px;text-overflow:ellipsis;white-space:nowrap}.status-dot{width:7px;height:7px;margin-left:auto;border-radius:50%;background:#16a34a;box-shadow:0 0 0 3px #dcfce7;flex:none}.status-panel details{margin-top:16px;border-top:1px solid #e2e8f0;padding-top:14px;color:#64748b;font-size:13px;line-height:1.6}.status-panel summary{color:#334155;font-weight:750;cursor:pointer}.status-panel details p{margin:10px 0 0}.totals{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.totals article{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:8px 10px;padding:18px;border:1px solid #d9dee5;border-radius:14px;background:white}.totals article>strong{font-size:15px}.totals dl{grid-column:1/-1;display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:8px 0 0}.totals dl div{display:grid;gap:2px}.totals dt{color:#64748b;font-size:11px}.totals dd{margin:0;font-size:18px;font-weight:800}.totals small{color:#64748b;font-size:10px;font-weight:600}.method{display:grid;grid-template-columns:minmax(210px,.7fr) 2fr;gap:40px;align-items:start;padding:28px 0;border-block:1px solid #d9dee5}.method p:last-child{margin:0;color:#64748b;line-height:1.65}.catalog-heading>p{max-width:420px;margin:0;color:#64748b;font-size:13px;text-align:right}.family{margin-top:24px}.family h3{display:flex;align-items:center;gap:8px;margin:0 0 9px;font-size:15px}.family h3 span{display:grid;min-width:22px;height:22px;place-items:center;border-radius:999px;background:#e8ecf3;color:#526075;font-size:11px}.matrix{overflow:hidden;border:1px solid #d9dee5;border-radius:14px;background:#fff}.matrix-head,.matrix-row{display:grid;grid-template-columns:minmax(150px,1.35fr) repeat(4,minmax(132px,1fr))}.matrix-head{position:sticky;top:0;z-index:2;background:#f5f7fa;border-bottom:1px solid #d9dee5}.matrix-head>div{display:flex;align-items:center;justify-content:center;gap:8px;padding:10px 12px;border-left:1px solid #e6e9ed;color:#475569;font-size:12px;font-weight:800}.matrix-head>div:first-child{justify-content:flex-start;border-left:0}.matrix-row{border-bottom:1px solid #e8ebef}.matrix-row:last-child{border-bottom:0}.matrix-row:hover{background:#fafbff}.component-cell{display:flex;align-items:center;justify-content:space-between;gap:10px;padding:12px 14px}.component-cell>a{color:#111827;font-size:14px;font-weight:800;text-decoration:none}.component-cell>span{display:flex;gap:3px;white-space:nowrap}.component-cell span a{color:#5264ae;font-size:11px;font-weight:750;text-decoration:none}.component-cell i{color:#5264ae;font-size:10px}.framework-cell{display:grid;grid-template-columns:1fr auto;align-content:center;gap:3px 8px;padding:9px 12px;border-left:1px solid #e8ebef;font-variant-numeric:tabular-nums}.receipt{grid-column:1/-1;display:flex;align-items:center;gap:7px;color:#166534;font-size:11px;font-weight:800;text-decoration:none;text-transform:capitalize}.receipt .status-dot{margin:0;width:6px;height:6px;box-shadow:none}.measure{color:#718096;font-size:10px;white-space:nowrap}.measure b{color:#334155;font-size:11px}.mobile-framework{display:none}section{margin-top:44px}
@media(max-width:900px){.status-grid,.totals{grid-template-columns:repeat(2,1fr)}.matrix-head,.matrix-row{grid-template-columns:minmax(140px,1.2fr) repeat(4,minmax(112px,1fr))}.matrix-head>div span{display:none}.framework-cell{grid-template-columns:1fr;padding:9px}.measure{font-size:9px}}
@media(max-width:640px){.hero{padding-top:16px}.hero h1{font-size:42px}.lede{font-size:16px}.hero-frameworks>span>span{display:none}.hero-frameworks>span{padding:8px}.status-panel{padding:17px}.section-heading{align-items:start}.score{display:grid;gap:0;text-align:right}.score strong{font-size:26px}.status-grid{grid-template-columns:1fr 1fr}.status-grid article{padding:10px}.status-grid article span:not(.status-dot){display:none}.totals{grid-template-columns:1fr 1fr;gap:8px}.totals article{padding:13px}.totals dl{grid-template-columns:1fr}.method{grid-template-columns:1fr;gap:16px}.catalog-heading{display:block}.catalog-heading>p{margin-top:8px;text-align:left}.matrix{overflow:visible;border:0;background:transparent}.matrix-head{display:none}.matrix-row{display:grid;grid-template-columns:1fr 1fr;overflow:hidden;margin-bottom:10px;border:1px solid #d9dee5!important;border-radius:13px;background:#fff}.component-cell{grid-column:1/-1;padding:13px;border-bottom:1px solid #e8ebef;background:#f8fafc}.framework-cell{display:grid;grid-template-columns:1fr auto;padding:10px 12px;border-left:0;border-bottom:1px solid #eef0f3}.framework-cell:nth-child(even){border-right:1px solid #eef0f3}.framework-cell:nth-last-child(-n+2){border-bottom:0}.mobile-framework{grid-column:1/-1;display:flex;align-items:center;gap:6px;color:#475569;font-size:11px;font-weight:800}.receipt{grid-column:1/-1}.measure{font-size:9px}.family h3{margin-top:18px}}
@media(max-width:390px){.status-grid,.totals{grid-template-columns:1fr}.matrix-row{grid-template-columns:1fr}.framework-cell{border-right:0!important;border-bottom:1px solid #eef0f3!important}.framework-cell:last-child{border-bottom:0!important}}
</style>
