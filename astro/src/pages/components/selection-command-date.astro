---
import Layout from '../../layouts/Layout.astro';
const components=['Radio','Autocomplete','Combobox','CommandPalette','DatePicker','DateRangePicker','DropdownMenu','Toasty','Pagination'];
---
<Layout title="Selection, command & date family">
<main><h1>Selection, command &amp; date family</h1><p>Nine components generated for React, Vue, Svelte, and Solid with SSR-safe initial markup and hydration behavior.</p><ul>{components.map(name=><li><strong>{name}</strong> — keyboard and ARIA contract included</li>)}</ul><p><a href="/selection-command-date/react">Open React runtime</a></p></main>
</Layout>
