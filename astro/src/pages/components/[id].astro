---
import catalog from '../../../../benchmarks/catalog.json';
export function getStaticPaths() {
  return catalog.components.map(component=>({params:{id:component.id},props:{component}}));
}
const {component}=Astro.props;
const frameworks=['react','vue','svelte','solid'];
---
<html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>{component.name} · Kumo</title><style>:root{--site-gutter:clamp(20px,4vw,48px)}*{box-sizing:border-box}body{margin:0;background:#f3f4f6;color:#111827;font:16px system-ui}.topbar{border-bottom:1px solid #d1d5db;background:white}.topbar-inner{width:min(100%,1196px);margin-inline:auto;padding:18px var(--site-gutter)}.topbar a{color:#111827;text-decoration:none;font-weight:800}.shell{width:min(100%,1196px);margin-inline:auto;padding:36px var(--site-gutter) 56px}h1{margin:0 0 8px;font-size:36px}p{max-width:850px;margin:0 0 24px;color:#64748b;line-height:1.55}.tabs{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}.tab{border:1px solid #d1d5db;background:white;border-radius:999px;padding:8px 14px;font-weight:800;cursor:pointer}.tab[aria-selected="true"]{background:#111827;color:white}.frame{display:block;width:100%;height:1200px;border:1px solid #d1d5db;border-radius:12px;background:white}@media(max-width:640px){.topbar-inner{padding-block:16px}.shell{padding-top:28px;padding-bottom:40px}h1{font-size:30px}}</style></head><body><nav class="topbar"><div class="topbar-inner"><a href="/">← Kumo catalog</a></div></nav><main class="shell"><h1>{component.name} runtime comparison</h1><p>React is the canonical input; these React, Vue, Svelte, and Solid panels are proof surfaces for observable output parity. See the catalog for evidence gates, measurements, and migration limitations.</p><div class="tabs" role="tablist">{frameworks.map((framework,index)=><button class="tab" role="tab" aria-selected={index===0 ? 'true':'false'} data-framework={framework}>{framework}</button>)}</div><iframe class="frame" id="runtime-frame" src={`/${component.id}/react`} title={`${component.name} runtime`}></iframe></main><script define:vars={{componentId:component.id}}>for(const button of document.querySelectorAll('[data-framework]'))button.addEventListener('click',()=>{document.querySelectorAll('[data-framework]').forEach(item=>item.setAttribute('aria-selected',String(item===button)));document.querySelector('#runtime-frame').src=`/${componentId}/${button.dataset.framework}/`})</script></body></html>
