---
import Layout from '../../layouts/Layout.astro';
import FrameworkIcon from '../../components/FrameworkIcon.astro';
import catalog from '../../../../benchmarks/catalog.json';
export function getStaticPaths() { return catalog.components.map(component => ({ params: { id: component.id }, props: { component } })); }
const { component } = Astro.props;
const frameworks = ['react','vue','svelte','solid'];
const names = { react: 'React', vue: 'Vue', svelte: 'Svelte', solid: 'Solid' };
---
<Layout title={`${component.name} · Kumo compiler`}>
  <header class="page-head"><p>Runtime comparison</p><h1>{component.name}</h1><span>One compiler fixture rendered by React, Vue, Svelte, and Solid.</span></header>
  <div class="tabs" role="tablist" aria-label="Framework runtime">{frameworks.map((framework,index) => <button class="tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-framework={framework}><FrameworkIcon framework={framework} size={20}/><span>{names[framework]}</span></button>)}</div>
  <iframe class="frame" id="runtime-frame" src={`/${component.id}/react`} title={`${component.name} React runtime`}></iframe>
  <script define:vars={{ componentId: component.id, names }}>
    for (const button of document.querySelectorAll('[data-framework]')) button.addEventListener('click', () => {
      document.querySelectorAll('[data-framework]').forEach(item => item.setAttribute('aria-selected', String(item === button)));
      const frame = document.querySelector('#runtime-frame');
      frame.src = `/${componentId}/${button.dataset.framework}`;
      frame.title = `${componentId} ${names[button.dataset.framework]} runtime`;
    });
  </script>
</Layout>
<style>
.page-head{margin-bottom:22px}.page-head p{margin:0 0 7px;color:#64748b;font-size:11px;font-weight:750;letter-spacing:.08em;text-transform:uppercase}.page-head h1{margin:0;font-size:clamp(32px,5vw,46px);letter-spacing:-.04em}.page-head span{display:block;margin-top:7px;color:#64748b;font-size:14px}.tabs{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:12px}.tab{display:flex;align-items:center;gap:7px;min-height:40px;border:1px solid #d1d5db;background:#fff;border-radius:8px;padding:7px 12px;color:#334155;font:inherit;font-size:13px;font-weight:750;cursor:pointer}.tab:hover{border-color:#94a3b8}.tab[aria-selected="true"]{border-color:#111827;background:#111827;color:#fff}.frame{display:block;width:100%;height:min(1200px,calc(100vh - 210px));min-height:560px;border:1px solid #d1d5db;border-radius:10px;background:#fff}@media(max-width:520px){.tabs{display:grid;grid-template-columns:repeat(4,1fr)}.tab{justify-content:center;padding:7px}.tab span{display:none}.frame{height:calc(100vh - 190px);min-height:500px}}
</style>
