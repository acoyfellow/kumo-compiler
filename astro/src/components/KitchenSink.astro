---
const frameworks = ['vue', 'svelte', 'solid'];
const sections = ['foundations', 'forms', 'navigation', 'collections', 'layers', 'data-layout', 'dates'];
---
<section class="sink" aria-labelledby="sink-title">
  <header class="intro"><p class="eyebrow">41 / 41 · receipts passed</p><h1 id="sink-title">The complete native component catalog.</h1><p>Every card below is rendered by the selected framework’s installed package tarball, with its contract unknowns and evidence links kept visible.</p></header>
  <div class="controls">
    <div class="switcher" role="tablist" aria-label="Catalog framework">
      {frameworks.map((framework, index) => <button type="button" role="tab" id={`sink-tab-${framework}`} aria-controls={`sink-${framework}`} aria-selected={index === 0 ? 'true' : 'false'} tabindex={index === 0 ? 0 : -1} data-sink-tab={framework}>{framework[0].toUpperCase() + framework.slice(1)}</button>)}
    </div>
    <nav class="section-index" aria-label="Component categories">{sections.map(section => <a href={`#${section}`} data-section-link={section}>{section.replace('-', ' & ')}</a>)}</nav>
  </div>
  {frameworks.map((framework, index) => <div class="panel" role="tabpanel" id={`sink-${framework}`} aria-labelledby={`sink-tab-${framework}`} hidden={index !== 0} data-sink-panel={framework}><iframe title={`${framework} installed-package all 41 component catalog`} src={`/library-gallery/${framework}/`} loading={index ? 'lazy' : 'eager'}></iframe></div>)}
  <p class="evidence"><strong>Catalog:</strong> all 41 native package components across Vue, Svelte, and Solid. <a href="/packages/manifest.json">Package provenance</a></p>
</section>
<script>
const tabs=[...document.querySelectorAll('[data-sink-tab]')],panels=[...document.querySelectorAll('[data-sink-panel]')];
function select(name){tabs.forEach(tab=>{const active=tab.dataset.sinkTab===name;tab.setAttribute('aria-selected',String(active));tab.tabIndex=active?0:-1});panels.forEach(panel=>panel.hidden=panel.dataset.sinkPanel!==name)}
tabs.forEach((tab,index)=>{tab.addEventListener('click',()=>select(tab.dataset.sinkTab));tab.addEventListener('keydown',event=>{if(!['ArrowLeft','ArrowRight','Home','End'].includes(event.key))return;event.preventDefault();const next=event.key==='Home'?0:event.key==='End'?tabs.length-1:(index+(event.key==='ArrowRight'?1:-1)+tabs.length)%tabs.length;select(tabs[next].dataset.sinkTab);tabs[next].focus()})});
document.querySelectorAll('[data-section-link]').forEach(link=>link.addEventListener('click',event=>{event.preventDefault();const panel=document.querySelector('[data-sink-panel]:not([hidden])');const frame=panel?.querySelector('iframe');frame?.contentWindow?.document.getElementById(link.dataset.sectionLink)?.scrollIntoView({behavior:'smooth'})}));
</script>
<style>
.sink{padding:clamp(32px,6vw,70px) 0}.intro{max-width:900px}.eyebrow{margin:0 0 10px;color:#b45309;font-size:12px;font-weight:850;letter-spacing:.1em;text-transform:uppercase}h1{margin:0;font-size:clamp(40px,7vw,72px);line-height:1;letter-spacing:-.05em}.intro>p:last-child{max-width:760px;color:#475569;font-size:19px;line-height:1.55}.controls{position:sticky;z-index:5;top:0;margin-top:28px;padding:10px 0;background:#f5f6f8;border-bottom:1px solid #e5e7eb}.switcher{display:flex;gap:6px;padding:5px;border:1px solid #d8dde5;border-radius:10px;background:#fff}.switcher button{flex:1;min-height:44px;border:1px solid transparent;border-radius:7px;background:transparent;color:#334155;font-weight:800}.switcher button[aria-selected=true]{border-color:#075fc7;background:#e8eef8;color:#0f172a}.section-index{display:flex;gap:14px;padding:10px 4px 0;overflow:auto;white-space:nowrap}.section-index a{color:#075fc7;font-size:13px;font-weight:700;text-transform:capitalize}.panel{margin-top:12px;border:1px solid #d8dde5;border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 8px 24px #0f172a0d}.panel iframe{display:block;width:100%;height:min(78vh,920px);min-height:660px;border:0;color-scheme:light;background:#fff}.evidence{margin:14px 0 0;padding:14px;border-left:4px solid #f48120;background:#fff7ed;color:#475569;line-height:1.5}.evidence a{color:#075fc7}@media(max-width:600px){.panel iframe{height:78vh;min-height:700px}.evidence{font-size:14px}}
</style>
