---
const { framework, size = 22 } = Astro.props;
const label = { react: 'React', vue: 'Vue', svelte: 'Svelte', solid: 'Solid' }[framework] ?? framework;
---
<span class={`framework-icon framework-icon--${framework}`} role="img" aria-label={label} title={label} style={`--icon-size:${size}px`}>
  {framework === 'react' && <svg viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="2.5" fill="currentColor"/><g fill="none" stroke="currentColor" stroke-width="1.7"><ellipse cx="16" cy="16" rx="14" ry="5.4"/><ellipse cx="16" cy="16" rx="14" ry="5.4" transform="rotate(60 16 16)"/><ellipse cx="16" cy="16" rx="14" ry="5.4" transform="rotate(120 16 16)"/></g></svg>}
  {framework === 'vue' && <svg viewBox="0 0 32 28" aria-hidden="true"><path fill="#41b883" d="M0 0h7l9 15.5L25 0h7L16 28z"/><path fill="#35495e" d="M7 0h5l4 7 4-7h5l-9 15.5z"/></svg>}
