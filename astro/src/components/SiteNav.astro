---
const path = Astro.url.pathname;
const links=[['/','Home'],['/examples/','Examples'],['/docs/','Docs'],['/docs/progress/','Progress'],['/docs/reference/packages/','Packages']];
---
<header class="site-nav"><div class="site-nav__inner"><a class="site-nav__brand" href="/" aria-label="Kumo compiler home">Kumo compiler</a><nav class="site-nav__desktop" aria-label="Primary">{links.map(([href,label])=><a href={href} aria-current={path===href?'page':undefined}>{label}</a>)}</nav><button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="mobile-navigation"><span class="sr-only">Open navigation</span><span></span><span></span><span></span></button></div><div class="site-nav__backdrop" hidden></div><nav id="mobile-navigation" class="site-nav__drawer" aria-label="Mobile" hidden><div class="site-nav__drawer-head"><strong>Navigate</strong><button type="button" data-close aria-label="Close navigation">×</button></div>{links.map(([href,label])=><a href={href} aria-current={path===href?'page':undefined}>{label}</a>)}<a href="/libraries/vue/">Vue library</a><a href="/libraries/svelte/">Svelte library</a><a href="/libraries/solid/">Solid library</a></nav></header>
<script>const root=document.querySelector('.site-nav'),toggle=root?.querySelector('.site-nav__toggle'),drawer=root?.querySelector('.site-nav__drawer'),backdrop=root?.querySelector('.site-nav__backdrop'),close=root?.querySelector('[data-close]');let previous;const setOpen=open=>{if(!toggle||!drawer||!backdrop)return;toggle.setAttribute('aria-expanded',String(open));drawer.hidden=!open;backdrop.hidden=!open;document.body.style.overflow=open?'hidden':'';if(open){previous=document.activeElement;close?.focus()}else if(previous instanceof HTMLElement)previous.focus()};toggle?.addEventListener('click',()=>setOpen(toggle.getAttribute('aria-expanded')!=='true'));close?.addEventListener('click',()=>setOpen(false));backdrop?.addEventListener('click',()=>setOpen(false));drawer?.querySelectorAll('a').forEach(link=>link.addEventListener('click',()=>setOpen(false)));document.addEventListener('keydown',event=>{if(event.key==='Escape')setOpen(false)});</script>
<style>.site-nav{position:sticky;top:0;z-index:50;border-bottom:1px solid #d8dde5;background:#fff}.site-nav__inner{display:flex;align-items:center;justify-content:space-between;width:min(100%,1200px);min-height:64px;margin:auto;padding:8px clamp(18px,4vw,40px)}.site-nav__brand{color:#111827;font-size:15px;font-weight:850;letter-spacing:-.015em;text-decoration:none}.site-nav__brand::after{content:"";display:inline-block;width:6px;height:6px;margin-left:5px;background:#f48120}.site-nav__desktop{display:flex;gap:6px}.site-nav__desktop a{display:inline-flex;align-items:center;min-height:44px;padding:0 11px;border-radius:7px;color:#334155;font-size:14px;font-weight:750;text-decoration:none}.site-nav__desktop a[aria-current=page]{background:#e8eef8;color:#111827}.site-nav__toggle{display:none;width:44px;height:44px;padding:10px;border:0;border-radius:7px;background:#f1f5f9}.site-nav__toggle span:not(.sr-only){display:block;width:22px;height:2px;margin:4px auto;background:#111827}.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}.site-nav__backdrop{position:fixed;inset:0;z-index:51;background:#0f172a99}.site-nav__drawer{position:fixed;top:0;right:0;z-index:52;width:min(88vw,360px);height:100dvh;padding:18px;background:#fff;box-shadow:-12px 0 40px #0f172a33}.site-nav__drawer-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid #d8dde5}.site-nav__drawer-head button{width:44px;height:44px;border:0;border-radius:7px;background:#f1f5f9;font-size:30px}.site-nav__drawer>a{display:flex;align-items:center;min-height:48px;padding:8px 12px;border-radius:7px;color:#111827;font-weight:750;text-decoration:none}.site-nav__drawer>a[aria-current=page]{background:#e8eef8}.site-nav a:focus-visible,.site-nav button:focus-visible{outline:3px solid #2563eb;outline-offset:2px}@media(max-width:700px){.site-nav__desktop{display:none}.site-nav__toggle{display:block}}@media(min-width:701px){.site-nav__drawer,.site-nav__backdrop{display:none!important}}</style>
