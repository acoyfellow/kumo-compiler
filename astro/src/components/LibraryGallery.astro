---
const { framework, packageName, sha256, receiptDigest } = Astro.props;
const title = framework[0].toUpperCase() + framework.slice(1);
const url = `https://kumo-compiler.coey.dev/packages/kumo-${framework}-0.0.1.tgz`;
const install = `npm install ${url}`;
const exampleUrl = `/examples/${framework}/`;
const docsUrl = `/docs/tutorials/first-library/`;
const code = framework === 'vue' ? `import { Button, Field } from '${packageName}';\nimport '${packageName}/styles.css';` : framework === 'svelte' ? `import { Button, Field } from '${packageName}';\nimport '${packageName}/styles.css';` : `import { Button, Field } from '${packageName}';\nimport '${packageName}/styles.css';`;
---
<header><p class="eyebrow">Kumo framework library</p><h1>{title} component library</h1><p class="lede">Install the packed, independently consumable {title} package and use its native components.</p><div class="hero-actions"><a class="primary" href={exampleUrl}>Open complete example</a><a href={docsUrl}>Read the tutorial</a></div></header>
<section aria-labelledby="live-title"><h2 id="live-title">Live package gallery</h2><p>This gallery is compiled from the installed tarball—not repository source.</p><iframe title={`${title} package-backed Button and Field gallery`} src={`/library-gallery/${framework}/`}></iframe></section>
<section><h2>Install</h2><div class="copy"><code>{install}</code><button type="button" data-copy={install} aria-describedby="copy-status">Copy</button></div><h2>Native usage</h2><div class="copy usage" tabindex="0" role="region" aria-label="Native usage code; scroll horizontally to view all content"><pre><code>{code}</code></pre><button type="button" data-copy={code} aria-describedby="copy-status">Copy</button></div><p id="copy-status" class="copy-status" role="status" aria-live="polite" aria-atomic="true"></p></section>
<section><h2>Components</h2><ul><li><strong>Button</strong> — native click handling, variants, sizes, loading and disabled states.</li><li><strong>Field</strong> — native model/input handling with label, description, error and ARIA wiring.</li></ul><p class="notice"><strong>Select is not included.</strong> Its package eligibility remains under evaluation.</p></section>
<section><h2>Use it elsewhere</h2><p>Download a complete Vite project with this production tarball in <code>package.json</code>, or follow the framework tutorial.</p><p><a href={exampleUrl} class="touch-link">View {title} example →</a> <a href={docsUrl} class="touch-link">Read documentation →</a></p>{framework === 'svelte' && <p class="notice"><strong>svelte.dev Playground status:</strong> the real import is registry-blocked because this package is not yet published to public npm. <a href="/docs/how-to/svelte-playground/">See the exact attempted import and result.</a></p>}</section><details><summary>Package evidence</summary><dl><dt>Package</dt><dd>{packageName}@0.0.1</dd><dt>SHA-256</dt><dd><code>{sha256}</code></dd><dt>Receipt digest</dt><dd><code>{receiptDigest}</code></dd></dl><p><a href="/packages/manifest.json" class="touch-link">View artifact manifest</a></p></details>
<script>document.querySelectorAll('[data-copy]').forEach(button=>button.addEventListener('click',async()=>{const status=document.querySelector('#copy-status');try{await navigator.clipboard.writeText(button.dataset.copy??'');button.textContent='Copied';if(status)status.textContent='Copied to clipboard.';}catch{button.textContent='Copy failed';if(status)status.textContent='Could not copy to clipboard. Select and copy the text manually.';}}));</script>
<style>
header{max-width:760px;margin-bottom:32px}.hero-actions{display:flex;flex-wrap:wrap;gap:10px;margin-top:20px}.hero-actions a{display:inline-flex;align-items:center;min-height:44px;padding:9px 13px;border:1px solid #94a3b8;border-radius:7px;color:#111827;font-weight:800;text-decoration:none}.hero-actions .primary{border-color:#075fc7;background:#075fc7;color:#fff}.eyebrow{margin:0 0 8px;color:#b45309;font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.08em}h1{margin:0;font-size:clamp(34px,6vw,60px);line-height:1}.lede{font-size:20px;line-height:1.5;color:#4b5563}section,details{margin:24px 0;padding:24px;border:1px solid #d8dde5;border-radius:12px;background:#fff}iframe{display:block;width:100%;height:390px;border:1px solid #d8dde5;border-radius:8px;background:#fff}.copy{display:flex;align-items:center;justify-content:space-between;gap:16px;max-width:100%;padding:14px;background:#111827;color:#f9fafb;border-radius:8px;overflow:auto}.copy pre{margin:0;min-width:max-content}.copy button{flex:none;min-height:44px;padding:8px 12px;border:0;border-radius:5px;font-weight:700;cursor:pointer}.usage{position:relative;padding-bottom:22px;background:linear-gradient(#111827,#111827) padding-box,linear-gradient(90deg,#2563eb,#93c5fd) border-box;border-bottom:5px solid transparent;scrollbar-gutter:stable}.usage:focus-visible{outline:3px solid #2563eb;outline-offset:3px}.copy-status{min-height:1.5em;margin:8px 0 0;color:#475569;font-size:14px}.notice{padding:12px;border-left:4px solid #f48120;background:#fff7ed}dl{display:grid;grid-template-columns:max-content minmax(0,1fr);gap:8px 16px}dd{margin:0;overflow-wrap:anywhere}@media(max-width:600px){section,details{padding:16px}iframe{height:430px}.copy{align-items:flex-start;flex-direction:column}dl{display:block}dt{margin-top:12px;font-weight:700}}
</style>
