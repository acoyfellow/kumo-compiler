---
import SiteNav from '../components/SiteNav.astro';
import SeoHead from '../components/SeoHead.astro';
const { title, description = 'Install and use the Kumo framework libraries.' } = Astro.props;
const path = Astro.url.pathname;
const groups = [
  { label: 'Start', links: [
    ['/docs/', 'Overview'],
    ['/docs/tutorials/first-library/', 'First library'],
    ['/examples/', 'Runnable examples']
  ]},
  { label: 'How-to', links: [
    ['/docs/how-to/install/', 'Install a package'],
    ['/docs/how-to/github/', 'Install from GitHub'],
    ['/docs/how-to/svelte-playground/', 'Svelte playground'],
    ['/docs/how-to/forms/', 'Build a form']
  ]},
  { label: 'Reference', links: [
    ['/docs/reference/packages/', 'Packages'],
    ['/docs/reference/button/', 'Button'],
    ['/docs/reference/field/', 'Field'],
    ['/docs/reference/styles/', 'Styles and tokens']
  ]},
  { label: 'Explanation', links: [
    ['/docs/explanation/distribution/', 'Distribution and playgrounds'],
    ['/docs/explanation/evidence/', 'Evidence and readiness']
  ]}
];
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><meta name="color-scheme" content="light"><title>{title} · Kumo docs</title><SeoHead title={`${title} · Kumo docs`} description={description} /><link rel="stylesheet" href="/kumo.css"><style>
:root{--gutter:clamp(18px,4vw,40px);color-scheme:light}*{box-sizing:border-box}html{background:#f5f6f8}body{margin:0;color:#111827;background:#f5f6f8;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;overflow-wrap:anywhere}.top{position:sticky;top:0;z-index:10;border-bottom:1px solid #d8dde5;background:#fff}.top-inner{display:flex;align-items:center;justify-content:space-between;width:min(100%,1320px);min-height:64px;margin:auto;padding:8px var(--gutter)}.brand{color:#111827;font-weight:850;text-decoration:none}.brand::after{content:"";display:inline-block;width:6px;height:6px;margin-left:5px;background:#f48120}.top-links{display:flex;gap:16px}.top-links a,.back{display:inline-flex;align-items:center;min-height:44px;color:#334155;font-weight:700;text-decoration:none}.layout{display:grid;grid-template-columns:240px minmax(0,820px);gap:clamp(28px,6vw,72px);width:min(100%,1320px);margin:auto;padding:36px var(--gutter) 80px}.sidebar{position:sticky;top:88px;align-self:start}.sidebar h2{margin:24px 0 6px;color:#64748b;font-size:12px;letter-spacing:.09em;text-transform:uppercase}.sidebar h2:first-child{margin-top:0}.sidebar a{display:flex;align-items:center;min-height:40px;padding:7px 10px;border-radius:7px;color:#334155;text-decoration:none}.sidebar a[aria-current=page]{background:#e8eef8;color:#0f172a;font-weight:800}.content{min-width:0}.content :global(h1){margin:0 0 16px;font-size:clamp(38px,6vw,64px);line-height:1;letter-spacing:-.045em}.content :global(h2){margin:48px 0 12px;font-size:27px;letter-spacing:-.02em}.content :global(h3){margin:28px 0 8px;font-size:20px}.content :global(p),.content :global(li){font-size:17px;line-height:1.7}.content :global(.lede){color:#475569;font-size:21px}.content :global(a){color:#075fc7;text-underline-offset:.18em}.content :global(pre){max-width:100%;overflow:auto;padding:18px;border-radius:10px;background:#111827;color:#f8fafc;font-size:14px;line-height:1.55}.content :global(code){font-family:ui-monospace,SFMono-Regular,Menlo,monospace}.content :global(:not(pre)>code){padding:.12rem .32rem;border-radius:4px;background:#e8eef8}.content :global(.note){margin:24px 0;padding:16px 18px;border-left:4px solid #f48120;background:#fff7ed;line-height:1.6}.content :global(.cards){display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px}.content :global(.card){display:block;padding:20px;border:1px solid #d8dde5;border-radius:10px;background:#fff;color:#111827;text-decoration:none}.content :global(.card strong){display:block;margin-bottom:6px;font-size:18px}.content :global(table){width:100%;min-width:650px;border-collapse:collapse;background:#fff}.content :global(.table-scroll){display:block;max-width:100%;overflow:auto;border:1px solid #d8dde5;border-radius:10px}.content :global(th),.content :global(td){padding:12px;border-bottom:1px solid #e5e7eb;text-align:left;vertical-align:top}.content :global(.actions){display:flex;flex-wrap:wrap;gap:10px;margin:24px 0}.content :global(.action){display:inline-flex;align-items:center;min-height:44px;padding:10px 14px;border-radius:7px;background:#075fc7;color:#fff;font-weight:800;text-decoration:none}.content :global(.action.secondary){border:1px solid #94a3b8;background:#fff;color:#111827}a:focus-visible,button:focus-visible{outline:3px solid #2563eb;outline-offset:3px}@media(max-width:780px){.layout{display:block;padding-top:20px}.sidebar{position:static;display:block;max-width:100%;margin-bottom:36px;padding:18px;border:1px solid #d8dde5;border-radius:10px;background:#fff}.sidebar section{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:4px 12px}.sidebar h2{grid-column:1/-1;margin:14px 0 4px}.sidebar h2:first-child{margin-top:0}.sidebar a{min-width:0}.content :global(.cards){grid-template-columns:1fr}}@media(max-width:480px){.top-links{gap:8px}.top-links a{font-size:14px}.content :global(h1){font-size:38px}.content :global(p),.content :global(li){font-size:16px}}
</style></head><body><SiteNav /><div class="layout"><aside class="sidebar" aria-label="Documentation"><section>{groups.map(group => <><h2>{group.label}</h2>{group.links.map(([href,label]) => <a href={href} aria-current={path === href ? 'page' : undefined}>{label}</a>)}</>)}</section></aside><main class="content"><slot /></main></div></body></html>
