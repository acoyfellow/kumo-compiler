---
const { title = 'Kumo Compiler' } = Astro.props;
const isRoot = Astro.url.pathname === '/';
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><meta name="color-scheme" content="light"><title>{title}</title><link rel="stylesheet" href="/kumo.css"><style>
:root{--gutter:clamp(18px,4vw,40px);color-scheme:light}*{box-sizing:border-box}html{overflow-x:hidden;background:#f5f6f8}body{min-width:0;margin:0;background:#f5f6f8;color:#111827;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased;overflow-wrap:anywhere}.nav{border-bottom:1px solid #d8dde5;background:#fff}.nav-inner{width:min(100%,1200px);margin:auto;padding:16px var(--gutter)}.brand,.back{display:inline-flex;align-items:center;min-height:44px;color:#111827;font-size:15px;font-weight:800;letter-spacing:-.015em;text-decoration:none}.brand::after{content:"";display:inline-block;width:6px;height:6px;margin-left:5px;border-radius:1px;background:#f48120}.shell{width:min(100%,1200px);min-width:0;margin:auto;padding:34px var(--gutter) 64px}a{text-underline-offset:.18em}a:focus-visible,button:focus-visible,summary:focus-visible{outline:3px solid #2563eb;outline-offset:3px;border-radius:2px}.table,.table-scroll{max-width:100%;overscroll-behavior-inline:contain;scrollbar-gutter:stable}.table:focus-visible,.table-scroll:focus-visible{outline:3px solid #2563eb;outline-offset:2px}@media(max-width:600px){.nav-inner{padding-block:8px}.shell{padding-top:24px;padding-bottom:48px}}
</style></head><body><nav class="nav"><div class="nav-inner">{isRoot ? <span class="brand">Kumo compiler</span> : <a class="back" href="/">← Component results</a>}</div></nav><main class="shell"><slot/></main></body></html>
