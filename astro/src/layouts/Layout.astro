---
const { title = 'Kumo Compiler' } = Astro.props;
const isRoot = Astro.url.pathname === '/';
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><meta name="color-scheme" content="light"><title>{title}</title><link rel="stylesheet" href="/kumo.css"><style>
:root{color-scheme:light}*{box-sizing:border-box}html{background:#f3f5f8}body{margin:0;background:radial-gradient(circle at 85% -5%,#edf0ff 0,transparent 30%),#f3f5f8;color:#111827;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;-webkit-font-smoothing:antialiased}.nav{position:relative;z-index:10;padding:17px max(22px,calc((100vw - 1180px)/2 + 28px));border-bottom:1px solid #d9dee5;background:rgb(255 255 255 / 88%);backdrop-filter:blur(14px)}.brand,.back{font-weight:850;letter-spacing:-.03em;text-decoration:none;color:inherit}.brand{font-size:22px}.brand::after{content:"";display:inline-block;width:7px;height:7px;margin-left:5px;border-radius:2px;background:#f48120}.back{font-size:14px}.shell{width:min(100%,1244px);margin:auto;padding:36px 32px 72px}@media(max-width:640px){.nav{padding:14px 18px}.shell{padding:24px 16px 56px}}
</style></head><body><nav class="nav">{isRoot ? <span class="brand">Kumo</span> : <a class="back" href="/">← Kumo catalog</a>}</nav><main class="shell"><slot/></main></body></html>
