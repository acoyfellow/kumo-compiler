---
const { title='Kumo Compiler' } = Astro.props;
const isRoot = Astro.url.pathname === '/';
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>{title}</title><link rel="stylesheet" href="/kumo.css"><style>body{margin:0;background:var(--color-surface-secondary,#f3f4f6);color:var(--text-color-surface,#111827);font-family:Inter,ui-sans-serif,system-ui,sans-serif}.nav{padding:20px 32px;border-bottom:1px solid var(--color-border,#d1d5db);background:var(--color-surface,#fff)}.brand,.back{font-weight:800;text-decoration:none;color:inherit}.brand{font-size:24px}.back{font-size:15px}.shell{max-width:1180px;margin:auto;padding:42px 32px}</style></head><body><nav class="nav">{isRoot ? <span class="brand">Kumo</span> : <a class="back" href="/">← Kumo catalog</a>}</nav><main class="shell"><slot/></main></body></html>
