---
const { title='Kumo Compiler' } = Astro.props;
const isRoot = Astro.url.pathname === '/';
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width"><title>{title}</title><link rel="stylesheet" href="/kumo.css"><style>:root{--site-gutter:clamp(20px,4vw,48px)}*{box-sizing:border-box}body{margin:0;background:var(--color-surface-secondary,#f3f4f6);color:var(--text-color-surface,#111827);font-family:Inter,ui-sans-serif,system-ui,sans-serif}.nav{border-bottom:1px solid var(--color-border,#d1d5db);background:var(--color-surface,#fff)}.nav-inner{width:min(100%,1244px);margin-inline:auto;padding:20px var(--site-gutter)}.brand,.back{font-weight:800;text-decoration:none;color:inherit}.brand{font-size:24px}.back{font-size:15px}.shell{width:min(100%,1244px);margin-inline:auto;padding:42px var(--site-gutter) 64px}@media(max-width:640px){.nav-inner{padding-block:16px}.shell{padding-top:28px;padding-bottom:44px}}</style></head><body><nav class="nav"><div class="nav-inner">{isRoot ? <span class="brand">Kumo</span> : <a class="back" href="/">← Kumo catalog</a>}</div></nav><main class="shell"><slot/></main></body></html>
