---
import SyntaxCode from '../components/SyntaxCode.astro';
const { title, framework, install, download, library } = Astro.props;
---
<html lang="en"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><meta name="color-scheme" content="light"><title>{title} · Kumo examples</title><link rel="stylesheet" href="/kumo.css"><style>:root{--gutter:clamp(18px,4vw,40px)}*{box-sizing:border-box}body{margin:0;background:#f5f6f8;color:#111827;font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif}.nav{border-bottom:1px solid #d8dde5;background:#fff}.nav-inner{display:flex;align-items:center;justify-content:space-between;width:min(100%,1120px);min-height:64px;margin:auto;padding:8px var(--gutter)}.nav a{display:inline-flex;align-items:center;min-height:44px;color:#111827;font-weight:800;text-decoration:none}.shell{width:min(100%,1120px);margin:auto;padding:42px var(--gutter) 80px}.eyebrow{color:#b45309;font-size:13px;font-weight:850;text-transform:uppercase;letter-spacing:.09em}h1{margin:8px 0;font-size:clamp(38px,6vw,64px);line-height:1;letter-spacing:-.04em}.lede{max-width:760px;color:#475569;font-size:20px;line-height:1.55}.actions{display:flex;flex-wrap:wrap;gap:10px;margin:24px 0 36px}.action{display:inline-flex;align-items:center;min-height:44px;padding:10px 14px;border-radius:7px;background:#075fc7;color:#fff;font-weight:800;text-decoration:none}.action.secondary{border:1px solid #94a3b8;background:#fff;color:#111827}.demo{padding:24px;border:1px solid #d8dde5;border-radius:12px;background:#fff}.demo iframe{display:block;width:100%;height:430px;border:1px solid #d8dde5;border-radius:8px}.grid{display:grid;grid-template-columns:minmax(0,1.2fr) minmax(0,.8fr);gap:20px;margin-top:22px}.panel{min-width:0;padding:20px;border:1px solid #d8dde5;border-radius:10px;background:#fff}.panel :global(h2){margin-top:0}.panel :global(pre){display:block;width:100%;max-width:100%;overflow-x:auto;padding:16px;border-radius:8px;background:#111827;color:#f8fafc;font-size:13px;line-height:1.55}.panel :global(code){font-family:ui-monospace,SFMono-Regular,Menlo,monospace}.panel :global(li),.panel :global(p){line-height:1.65}.note{padding:14px;border-left:4px solid #f48120;background:#fff7ed}a:focus-visible{outline:3px solid #2563eb;outline-offset:3px}@media(max-width:760px){.grid{grid-template-columns:1fr}.shell{padding-top:26px}.demo{padding:16px}.demo iframe{height:470px}}</style></head><body><nav class="nav"><div class="nav-inner"><a href="/examples/">← Examples</a><a href="/docs/">Docs</a></div></nav><main class="shell"><p class="eyebrow">{framework} complete example</p><h1>{title}</h1><p class="lede">A complete project that installs the production tarball and renders the same Button and Field contract shown in the live gallery.</p><div class="actions"><a class="action" href={download} download>Download project</a><a class="action secondary" href={library}>Library page</a></div><section class="demo"><iframe title={`${framework} Kumo package example`} src={`/library-gallery/${framework}/`}></iframe></section><div class="grid"><section class="panel"><slot /></section><aside class="panel"><h2>Install</h2><SyntaxCode lang="shell" label="Terminal" code={install} /><h2>What this proves</h2><ul><li>Package URL installs through npm</li><li>Root component exports resolve</li><li>Package CSS is applied</li><li>Button and Field run in the target framework</li></ul><p class="note">Select is not included. Registry-only playgrounds need public npm publication.</p></aside></div></main></body></html>
