  "styleVariantProp": "variant",
  "defaultVariant": "secondary",
  "shapeVariants": [
    {
      "when": {
        "shape": "square"
      },
      "classes": [
        "justify-center",
        "p-0",
        "size-9"
      ]
    },
    {
      "when": {
        "shape": "circle"
      },
      "classes": [
        "justify-center",
        "p-0",
        "rounded-full",
        "size-9"
      ]
    }
  ],
  "shapeProp": "shape",
  "defaultShape": "base",
  "sizeVariants": [
    {
      "when": {
        "size": "xs"
      },
      "classes": [
        "h-5",
        "gap-1",
        "rounded-sm",
        "px-1.5",
        "text-xs"
      ]
    },
    {
      "when": {
        "size": "sm"
      },
      "classes": [
        "h-6.5",
        "gap-1",
        "rounded-md",
        "px-2",
        "text-xs"
      ]
    },
    {
      "when": {
        "size": "lg"
      },
      "classes": [
        "h-10",
        "gap-2",
        "px-4"
      ]
    }
  ],
  "sizeProp": "size",
  "defaultSize": "base",
  "emphasis": {
    "prop": "variant",
    "overlayClass": "absolute inset-0 rounded-[inherit] bg-linear-to-b from-(--kumo-button-emphasis-gradient-start) to-(--kumo-button-emphasis-gradient-end) translate-y-px group-hover:from-(--kumo-button-emphasis-bg)",
    "wrapperClass": "relative flex items-center gap-1.5",
    "variants": {
      "primary": {
        "--kumo-button-emphasis-ring": "color-mix(in oklch, var(--color-kumo-brand), black 10%)",
        "--kumo-button-emphasis-bg": "color-mix(in oklch, var(--color-kumo-brand), white 30%)",
        "--kumo-button-emphasis-gradient-start": "color-mix(in oklch, var(--color-kumo-brand), white 15%)",
        "--kumo-button-emphasis-gradient-end": "var(--color-kumo-brand)"
      },
      "destructive": {
        "--kumo-button-emphasis-ring": "color-mix(in oklch, var(--color-kumo-danger), black 10%)",
        "--kumo-button-emphasis-bg": "color-mix(in oklch, var(--color-kumo-danger), white 30%)",
        "--kumo-button-emphasis-gradient-start": "color-mix(in oklch, var(--color-kumo-danger), white 15%)",
        "--kumo-button-emphasis-gradient-end": "var(--color-kumo-danger)"
      },
      "danger": {
        "--kumo-button-emphasis-ring": "color-mix(in oklch, var(--color-kumo-danger), black 10%)",
        "--kumo-button-emphasis-bg": "color-mix(in oklch, var(--color-kumo-danger), white 30%)",
        "--kumo-button-emphasis-gradient-start": "color-mix(in oklch, var(--color-kumo-danger), white 15%)",
        "--kumo-button-emphasis-gradient-end": "var(--color-kumo-danger)"
      }
    }
  },
  "events": {
    "click": {
      "native": true,
      "suppressedWhen": [
        "disabled",
        "loading"
      ]
    },
    "submit": {
      "nativeForm": true,
      "when": {
        "prop": "type",
        "equals": "submit"
      }
    }
  },
  "vectorIds": [
    "disabled-click",
    "loading-click",
    "enabled-click",
    "submit-form"
  ],
