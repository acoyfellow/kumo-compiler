  "nativeAttributes": true,
  "disabledWhen": [
    {
      "prop": "disabled",
      "equals": true
    },
    {
      "prop": "loading",
      "equals": true
    }
  ],
  "loadingIndicator": {
    "when": {
      "prop": "loading",
      "equals": true
    },
    "tag": "svg",
    "attributes": {
      "aria-hidden": "true"
    },
    "beforeContent": true
  },
