{
  "schemaVersion": "kumo.dialog-layer/v1",
  "component": "dialog",
  "support": "supported",
  "api": {
    "exports": [
      "Dialog",
      "DialogRoot",
      "DialogTrigger",
      "DialogTitle",
      "DialogDescription",
      "DialogClose"
    ],
    "compound": [
      ".Root",
      ".Trigger",
      ".Title",
      ".Description",
      ".Close"
    ]
  },
  "trigger": {
    "tag": "button",
    "attributes": {
      "data-kumo-component": "Dialog",
      "data-kumo-part": "trigger"
    }
  },
  "closed": {
    "dialogCount": 0
  },
  "open": {
    "role": "dialog",
    "portalCount": 1,
    "container": "KumoPortalProvider container or document.body"
  },
  "lifecycle": {
    "openOn": "click trigger",
    "closeOn": "click [data-kumo-part=close]",
    "event": "open:<bool>",
    "events": [
      "open:true",
      "open:false"
    ]
  },
  "focus": {
    "restore": "trigger"
  },
  "unknowns": [
    {
      "field": "modality",
      "status": "unknown",
      "reason": "Inert outside content, scroll-lock, and Tab focus containment require canonical browser execution not asserted by the contract."
    },
    {
      "field": "generatedIds",
      "status": "unknown",
      "reason": "Title/description association ids are generated by Base UI and are not stable contract surface."
    },
    {
      "field": "alertdialogEscape",
      "status": "unknown",
      "reason": "Alertdialog escape policy is not asserted by the canonical contract."
    }
  ],
  "vectorIds": [
    "closed-trigger",
    "open-and-close"
  ],
  "provenance": {
    "component": "dialog",
    "contractPath": "contracts/kumo.observable/v1/components/dialog.json",
    "contractDigest": "15bdd0b64f302b4a64929843f7958278d13b196cc80702033dbf526db845a5e3",
    "vectorIds": [
      "closed-trigger",
      "open-and-close"
    ]
  },
