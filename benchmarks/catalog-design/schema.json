{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kumo.example/schemas/benchmark-catalog-run-v1.json",
  "title": "Kumo component benchmark catalog run",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "runId", "siteBaseUrl", "createdAt", "source", "environment", "components", "packageProof"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "runId": { "$ref": "#/$defs/nonEmpty" },
    "siteBaseUrl": { "type": "string", "format": "uri" },
    "createdAt": { "type": "string", "format": "date-time" },
    "source": { "$ref": "#/$defs/source" },
    "environment": { "$ref": "#/$defs/environment" },
    "components": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/component" } },
    "packageProof": { "$ref": "#/$defs/packageProof" },
    "compilerComparisons": { "type": "array", "items": { "$ref": "#/$defs/compilerComparison" } }
  },
  "$defs": {
    "nonEmpty": { "type": "string", "minLength": 1 },
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "path": { "type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$" },
    "route": { "type": "string", "pattern": "^/[^?#]*$" },
    "bytes": { "type": "integer", "minimum": 0 },
    "milliseconds": { "type": "number", "minimum": 0 },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["repository", "commit", "dirty"],
      "properties": {
        "repository": { "type": "string", "format": "uri" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" },
        "branch": { "type": "string" },
        "dirty": { "type": "boolean" }
      }
    },
    "environment": {
      "type": "object", "additionalProperties": false,
      "required": ["fingerprint", "os", "architecture", "cpu", "logicalCpus", "memoryBytes", "tools"],
      "properties": {
        "fingerprint": { "$ref": "#/$defs/sha256" },
        "os": { "$ref": "#/$defs/nonEmpty" },
        "architecture": { "$ref": "#/$defs/nonEmpty" },
        "cpu": { "$ref": "#/$defs/nonEmpty" },
        "logicalCpus": { "type": "integer", "minimum": 1 },
        "memoryBytes": { "$ref": "#/$defs/bytes" },
        "tools": {
          "type": "object", "minProperties": 1,
          "additionalProperties": { "type": "string", "minLength": 1 },
          "description": "Tool-to-version map, such as node, npm, chrome, cargo, and rustc."
        },
        "notes": { "type": "string" }
      }
    },
    "component": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "name", "specPath", "scenario", "frameworks"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "name": { "$ref": "#/$defs/nonEmpty" },
        "specPath": { "$ref": "#/$defs/path" },
        "scenario": { "$ref": "#/$defs/scenario" },
        "frameworks": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/frameworkResult" } }
      }
    },
    "scenario": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "revision", "description", "iframeRoutes", "captureConfig"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "revision": { "type": "integer", "minimum": 1 },
        "description": { "$ref": "#/$defs/nonEmpty" },
        "states": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/nonEmpty" } },
        "iframeRoutes": {
          "type": "object", "minProperties": 1,
          "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
          "additionalProperties": { "$ref": "#/$defs/route" }
        },
        "captureConfig": { "$ref": "#/$defs/captureConfig" }
      }
    },
    "captureConfig": {
      "type": "object", "additionalProperties": false,
      "required": ["viewport", "deviceScaleFactor", "colorScheme", "reducedMotion", "locale", "fontPolicy"],
      "properties": {
        "viewport": {
          "type": "object", "additionalProperties": false, "required": ["width", "height"],
          "properties": { "width": { "type": "integer", "minimum": 1 }, "height": { "type": "integer", "minimum": 1 } }
        },
        "deviceScaleFactor": { "type": "number", "exclusiveMinimum": 0 },
        "colorScheme": { "enum": ["light", "dark"] },
        "reducedMotion": { "enum": ["reduce", "no-preference"] },
        "locale": { "$ref": "#/$defs/nonEmpty" },
        "fontPolicy": { "$ref": "#/$defs/nonEmpty" },
        "browserArguments": { "type": "array", "items": { "type": "string" } }
      }
    },
    "frameworkResult": {
      "type": "object", "additionalProperties": false,
      "required": ["framework", "route", "reference", "status"],
      "properties": {
        "framework": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "version": { "$ref": "#/$defs/nonEmpty" },
        "route": { "$ref": "#/$defs/route" },
        "reference": { "type": "boolean" },
        "status": { "enum": ["measured", "failed", "unsupported"] },
        "failureReason": { "$ref": "#/$defs/nonEmpty" },
        "metrics": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "ssr": { "$ref": "#/$defs/ssrTiming" },
            "hydration": { "$ref": "#/$defs/hydrationTiming" },
            "screenshot": { "$ref": "#/$defs/screenshot" },
            "bundle": { "$ref": "#/$defs/bundle" }
          }
        }
      },
      "allOf": [
        { "if": { "properties": { "status": { "const": "measured" } }, "required": ["status"] }, "then": { "required": ["version", "metrics"] } },
        { "if": { "properties": { "status": { "enum": ["failed", "unsupported"] } }, "required": ["status"] }, "then": { "required": ["failureReason"] } }
      ]
    },
    "timingSummary": {
      "type": "object",
      "required": ["unit", "samples", "median", "p95", "minimum", "maximum", "summaryMethod"],
      "properties": {
        "unit": { "const": "ms" },
        "samples": { "type": "array", "minItems": 5, "items": { "$ref": "#/$defs/milliseconds" } },
        "median": { "$ref": "#/$defs/milliseconds" },
        "p95": { "$ref": "#/$defs/milliseconds" },
        "minimum": { "$ref": "#/$defs/milliseconds" },
        "maximum": { "$ref": "#/$defs/milliseconds" },
        "warmupRuns": { "type": "integer", "minimum": 0 },
        "summaryMethod": { "enum": ["nearest-rank", "linear-interpolation"] }
      }
    },
    "ssrTiming": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/timingSummary" },
        {
          "type": "object",
          "required": ["kind", "method"],
          "properties": {
            "kind": { "enum": ["ssr", "static-response"] },
            "method": { "$ref": "#/$defs/nonEmpty" }
          }
        }
      ]
    },
    "hydrationTiming": {
      "type": "object",
      "unevaluatedProperties": false,
      "allOf": [
        { "$ref": "#/$defs/timingSummary" },
        {
          "type": "object",
          "required": ["method", "startMark", "endMark", "includesBrowserStartup"],
          "properties": {
            "method": { "$ref": "#/$defs/nonEmpty" },
            "startMark": { "$ref": "#/$defs/nonEmpty" },
            "endMark": { "$ref": "#/$defs/nonEmpty" },
            "includesBrowserStartup": { "type": "boolean" }
          }
        }
      ]
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["url", "sha256", "bytes"],
      "properties": {
        "url": { "$ref": "#/$defs/route" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "$ref": "#/$defs/bytes" }
      }
    },
    "screenshot": {
      "type": "object", "additionalProperties": false,
      "required": ["format", "width", "height", "artifact"],
      "properties": {
        "format": { "const": "png" },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "artifact": { "$ref": "#/$defs/artifact" },
        "comparison": {
          "type": "object", "additionalProperties": false,
          "required": ["referenceFramework", "algorithm", "referenceSha256", "pixelDiff"],
          "properties": {
            "referenceFramework": { "$ref": "#/$defs/nonEmpty" },
            "algorithm": { "enum": ["exact-rgba"] },
            "referenceSha256": { "$ref": "#/$defs/sha256" },
            "pixelDiff": {
              "type": "object", "additionalProperties": false, "required": ["changedPixels", "totalPixels"],
              "properties": {
                "changedPixels": { "type": "integer", "minimum": 0 },
                "totalPixels": { "type": "integer", "minimum": 1 },
                "diffArtifact": { "$ref": "#/$defs/artifact" }
              }
            }
          }
        }
      }
    },
    "bundleFile": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "type", "rawBytes", "gzipBytes", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/path" },
        "type": { "enum": ["js", "css", "map", "asset", "html", "other"] },
        "rawBytes": { "$ref": "#/$defs/bytes" },
        "gzipBytes": { "$ref": "#/$defs/bytes" },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "bundle": {
      "type": "object", "additionalProperties": false,
      "required": ["tool", "mode", "includesSourceMaps", "gzip", "files", "totals"],
      "properties": {
        "tool": { "$ref": "#/$defs/nonEmpty" },
        "mode": { "$ref": "#/$defs/nonEmpty" },
        "includesSourceMaps": { "type": "boolean" },
        "gzip": {
          "type": "object", "additionalProperties": false, "required": ["level", "mtime"],
          "properties": { "level": { "const": 9 }, "mtime": { "const": 0 } }
        },
        "files": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bundleFile" } },
        "totals": {
          "type": "object", "additionalProperties": false, "required": ["rawBytes", "gzipBytes"],
          "properties": { "rawBytes": { "$ref": "#/$defs/bytes" }, "gzipBytes": { "$ref": "#/$defs/bytes" } }
        }
      }
    },
    "packageFile": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": { "path": { "$ref": "#/$defs/path" }, "bytes": { "$ref": "#/$defs/bytes" }, "sha256": { "$ref": "#/$defs/sha256" } }
    },
    "packageProof": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "command", "packageManager", "packageName", "packageVersion", "workingTreeClean", "tarball", "packedBytes", "unpackedBytes", "totalFiles", "files", "requiredArtifacts"],
      "properties": {
        "status": { "enum": ["passed", "failed"] },
        "command": { "$ref": "#/$defs/nonEmpty" },
        "packageManager": { "$ref": "#/$defs/nonEmpty" },
        "packageName": { "$ref": "#/$defs/nonEmpty" },
        "packageVersion": { "$ref": "#/$defs/nonEmpty" },
        "workingTreeClean": { "type": "boolean" },
        "tarball": {
          "type": "object", "additionalProperties": false, "required": ["filename", "sha256"],
          "properties": { "filename": { "$ref": "#/$defs/path" }, "sha256": { "$ref": "#/$defs/sha256" } }
        },
        "packedBytes": { "$ref": "#/$defs/bytes" },
        "unpackedBytes": { "$ref": "#/$defs/bytes" },
        "totalFiles": { "type": "integer", "minimum": 0 },
        "files": { "type": "array", "items": { "$ref": "#/$defs/packageFile" } },
        "requiredArtifacts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false, "required": ["pattern", "matched", "matches"],
            "properties": {
              "pattern": { "$ref": "#/$defs/nonEmpty" },
              "matched": { "type": "boolean" },
              "matches": { "type": "array", "items": { "$ref": "#/$defs/path" } }
            }
          }
        },
        "rawProofArtifact": { "$ref": "#/$defs/artifact" },
        "failureReason": { "$ref": "#/$defs/nonEmpty" }
      }
    },
    "compilerImplementation": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "language", "runtime", "command", "wallTime", "outputBytes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "language": { "$ref": "#/$defs/nonEmpty" },
        "runtime": { "$ref": "#/$defs/nonEmpty" },
        "command": { "$ref": "#/$defs/nonEmpty" },
        "executableSha256": { "$ref": "#/$defs/sha256" },
        "wallTime": { "$ref": "#/$defs/timingSummary" },
        "outputBytes": { "$ref": "#/$defs/bytes" }
      }
    },
    "compilerComparison": {
      "type": "object", "additionalProperties": false,
      "required": ["componentId", "specPath", "scope", "timingScope", "excluded", "implementations", "equivalence"],
      "properties": {
        "componentId": { "$ref": "#/$defs/nonEmpty" },
        "specPath": { "$ref": "#/$defs/path" },
        "scope": { "$ref": "#/$defs/nonEmpty" },
        "timingScope": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/nonEmpty" } },
        "excluded": { "type": "array", "items": { "$ref": "#/$defs/nonEmpty" } },
        "implementations": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/compilerImplementation" } },
        "equivalence": {
          "type": "object", "additionalProperties": false,
          "required": ["baselineImplementation", "algorithm", "paths", "outputs", "equivalent"],
          "properties": {
            "baselineImplementation": { "$ref": "#/$defs/nonEmpty" },
            "algorithm": { "enum": ["byte-for-byte"] },
            "paths": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/path" } },
            "outputs": {
              "type": "object", "minProperties": 2,
              "additionalProperties": { "$ref": "#/$defs/sha256" }
            },
            "equivalent": { "type": "boolean" }
          }
        }
      }
    }
  }
}
