{
  "name": "kumo-compiler",
  "version": "0.0.1",
  "description": "Private Kumo compiler and proof application.",
  "scripts": {
    "compile:kumo": "tsc -p tsconfig.kumo.json && node dist/kumo/compiler.js",
    "matrix:kumo": "node scripts/run-kumo-matrix.mjs",
    "protocol:fixture": "node scripts/compiler-protocol/fixture.mjs",
    "protocol:conformance": "node scripts/compiler-protocol/conformance.mjs",
    "upstream:check": "node scripts/upstream-check.mjs",
    "upstream:rollback": "node scripts/upstream-rollback.mjs",
    "upstream:rehearse": "node rehearsals/upstream/rehearse.mjs all",
    "upstream:rehearse:validate": "node rehearsals/upstream/validate.mjs",
    "protocol:benchmark": "node scripts/compiler-protocol/benchmark.mjs",
    "protocol:benchmark:validate": "node scripts/compiler-protocol/validate-benchmark.mjs",
    "matrix:kumo:shard": "node scripts/run-kumo-shard.mjs",
    "build:kumo:vue": "npm run compile:kumo && node scripts/build-from-manifest.mjs kumo-vue",
    "verify:kumo:vue": "node scripts/verify-kumo-vue.mjs",
    "generate:kumo:react": "node scripts/generate-canonical-react-runtimes.mjs",
    "build:kumo:react": "npm run generate:kumo:react && node scripts/build-canonical-react-runtimes.mjs",
    "proof:kumo:react": "npm run build:kumo:react && node proof/catalog-browser-proof.mjs --frameworks=react && node scripts/audit-kumo-react.mjs",
    "audit:kumo:react": "npm run generate:kumo:react && node scripts/audit-kumo-react.mjs",
    "compile:kumo:svelte": "npm run compile:kumo && node dist/kumo/svelte-compiler.js",
    "compile:kumo:solid": "npm run compile:kumo && node dist/kumo/solid-compiler.js",
    "build:kumo:solid": "npm run compile:kumo:solid && node scripts/build-kumo-solid.mjs",
    "verify:kumo:solid": "node scripts/verify-kumo-solid.mjs",
    "proof:kumo:solid": "npm run build:kumo:solid && npm run verify:kumo:solid",
    "build:kumo:svelte": "npm run compile:kumo:svelte && node scripts/build-from-manifest.mjs kumo-svelte",
    "verify:kumo:svelte": "node scripts/verify-kumo-svelte.mjs",
    "proof:kumo:svelte": "npm run build:kumo:svelte && npm run verify:kumo:svelte && npm run package:verify && npm run catalog:validate",
    "build:migration-status": "node scripts/build-migration-status.mjs",
    "contract:new": "node scripts/contract-new.mjs",
    "serve": "node review/server.mjs",
    "catalog:validate": "node benchmarks/catalog.mjs",
    "catalog:build": "node benchmarks/catalog.mjs --build",
    "test": "node --test test/*.test.mjs",
    "test:catalog-browser-proof": "node --test test/catalog-browser-proof.test.mjs",
    "proof:catalog-browser": "node proof/catalog-browser-proof.mjs",
    "proof:production": "node proof/production-proof.mjs",
    "proof:library-pages": "node proof/library-pages/run.mjs",
    "evidence:validate": "node scripts/browser-evidence-authority.mjs",
    "manifest:validate": "node scripts/verify-package.mjs",
    "package:verify": "node scripts/verify-package.mjs",
    "artifact:check": "node scripts/check-artifact-boundary.mjs",
    "docs:links": "node scripts/validate-astro-routes.mjs",
    "release:install": "npm --prefix astro ci",
    "libraries:build": "node scripts/libraries/build.mjs",
    "libraries:gallery": "node scripts/libraries/build-gallery.mjs",
    "examples:build": "node scripts/build-examples.mjs",
    "release:github": "node scripts/github-release.mjs",
    "release:github:verify": "node scripts/verify-github-release.mjs",
    "release:npm:preflight": "node scripts/npm-publish-preflight.mjs",
    "libraries:verify": "node scripts/libraries/verify.mjs",
    "deploy:prepare": "node scripts/prepare-deploy.mjs",
    "deploy:dry-run": "npm run deploy:prepare && node scripts/deploy.mjs",
    "deploy": "npm run deploy:prepare && node scripts/deploy.mjs --execute",
    "rollback:dry-run": "node scripts/rollback.mjs",
    "rollback": "node scripts/rollback.mjs --execute",
    "release:check": "npm run release:install && npm run libraries:build && npm run libraries:gallery && npm run examples:build && npm run release:github && npm run release:github:verify && npm run release:npm:preflight && npm test && npm run artifact:check && npm run package:verify && npm run evidence:validate && npm run build:migration-status && npm run deploy:prepare && npm run catalog:validate && npm run docs:links",
    "workflow:plan": "node scripts/workflow-plan.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "hono": "^4.12.26",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@cloudflare/kumo": "2.5.2",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@vitejs/plugin-react": "6.0.2",
    "@types/node": "^22.20.0",
    "@vitejs/plugin-vue": "6.0.7",
    "solid-js": "1.9.13",
    "svelte": "5.56.3",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "vite-plugin-solid": "2.11.12",
    "vue": "3.5.38"
  },
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "packageManager": "npm@11.13.0"
}
