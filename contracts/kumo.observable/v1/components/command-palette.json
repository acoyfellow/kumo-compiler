  "semantics": {
    "root": "div",
    "aria": [
      "open Root/Dialog renders modal dialog and backdrop",
      "Panel input uses autocomplete combobox semantics",
      "items expose highlighted and disabled state",
      "focus is trapped/restored by Base UI dialog"
    ]
  },
  "initialState": {
    "open": "required controlled boolean",
    "query": "controlled value or empty",
    "highlight": "first result auto-highlighted always and kept as results change",
    "modal": true
  },
  "transitions": [
    {
      "action": "backdrop click",
      "effect": "calls onBackdropClick when provided, otherwise onOpenChange(false)"
    },
    {
      "action": "Escape in Input",
      "effect": "prevents default and closes dialog"
    },
    {
      "action": "ArrowDown/ArrowUp",
      "effect": "moves highlight and calls onItemHighlighted"
    },
    {
      "action": "Enter",
      "effect": "selects highlighted autocomplete item"
    },
    {
      "action": "Meta+Enter or Control+Enter",
      "effect": "with onSelect and getSelectableItems calls onSelect(item,{newTab:true})"
    }
  ],
  "keyboardFocus": {
    "focusable": true,
    "keys": [
      "ArrowDown",
      "ArrowUp",
      "Enter",
      "Meta+Enter",
      "Control+Enter",
      "Escape"
    ]
  },
  "ssrHydration": {
    "ssr": "supported",
    "hydration": "identical"
  },
