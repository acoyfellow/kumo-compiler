    "props": {
      "root": "HTMLAttributes<HTMLElement>; aria-label defaults to Table of contents",
      "Title": "HTMLAttributes<HTMLParagraphElement>",
      "List": "HTMLAttributes<HTMLUListElement>",
      "Item": "AnchorHTMLAttributes<HTMLAnchorElement> plus active?: boolean and render?: ReactElement",
      "Group": "HTMLAttributes<HTMLLIElement> minus title, plus required label, optional href and active"
    },
    "defaults": {
      "root.aria-label": "Table of contents",
      "Item.active": false,
      "Group.active": false
    }
  },
  "semantics": {
    "root": "nav containing consumer-composed title/list/items/groups",
    "aria": [
      "root is a navigation landmark with default aria-label Table of contents",
      "active Item emits aria-current=true; inactive Item omits aria-current",
      "Group emits aria-current=true only when href is present and active is true",
      "component is controlled/presentational: consumer owns scroll tracking and active state",
      "Group always nests its children in a ul; label is an anchor when href exists and otherwise a paragraph"
    ]
  },
  "initialState": {
    "active": "exactly as supplied per Item or linked Group; no internal selection state"
  },
  "transitions": [],
  "keyboardFocus": {
    "focusable": true,
    "keys": [
      "native anchor navigation only; no component-managed keys"
    ]
  },
