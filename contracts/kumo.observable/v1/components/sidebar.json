  "semantics": {
    "root": "Provider wrapper div; desktop Sidebar root is aside, mobile root is portaled backdrop plus nav",
    "aria": [
      "all Sidebar descendants require Provider; useSidebar outside it throws",
      "desktop collapse modes are icon, offcanvas, or none; none always renders expanded aside",
      "viewport below mobileBreakpoint renders a modal-like nav sheet labelled Navigation instead of aside",
      "closed mobile nav has aria-hidden=true and is made inert by ref effect; open focuses first focusable descendant or nav",
      "Escape closes mobile sheet and restores prior focus; focus leaving open sheet closes it",
      "Trigger exposes aria-expanded and Collapse sidebar/Expand sidebar label; Rail is tabIndex -1; ResizeHandle is keyboard focusable",
      "Collapsible trigger receives aria-expanded and aria-controls; content stays mounted as role=region and closed content has aria-hidden=true plus inert after ref effect",
      "inactive SlidingView stays mounted with aria-hidden=true, pointer-events-none and inert after ref effect",
      "MenuButton/MenuSubButton auto-wrap in li when not already inside corresponding item"
    ]
  },
  "initialState": {
    "state": "expanded when defaultOpen true, otherwise collapsed; peeking while transient peek is active",
    "openMobile": false,
    "width": "defaultWidth, clamped only when setWidth is called",
    "isMobile": "false during SSR because window is absent",
    "isResizing": false,
    "isPeeking": false
  },
  "transitions": [
    {
      "action": "Trigger or Rail click",
      "effect": "toggles desktop open, or mobile openMobile; desktop toggle stops peeking"
    },
    {
      "action": "hover/focus enters collapsed desktop peek zone when peekable",
      "effect": "state becomes peeking until pointer/focus leaves"
    },
    {
      "action": "ResizeHandle drag or directional arrow",
      "effect": "width is clamped to minWidth/maxWidth; crossing inward below minWidth collapses, dragging outward to minWidth expands"
    },
    {
      "action": "ResizeHandle Home/End",
      "effect": "Home collapses; End expands at maxWidth"
    },
    {
      "action": "CollapsibleTrigger click",
      "effect": "toggles controlled callback and internal open state"
    },
    {
      "action": "focus-visible enters closed Collapsible",
      "effect": "temporarily opens; blur closes unless explicitly opened or descendant has data-active"
    },
    {
      "action": "SlidingViews activeKey changes",
      "effect": "track translates to active child index; inactive children become hidden/inert"
    }
  ],
  "keyboardFocus": {
    "focusable": true,
    "keys": [
      "Escape",
      "ArrowLeft",
      "ArrowRight",
      "Home",
      "End",
      "Tab"
    ]
  },
