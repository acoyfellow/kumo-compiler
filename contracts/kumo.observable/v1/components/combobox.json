      "root": "Base UI generic Root props plus label,required,labelTooltip,description,error,size",
      "variants": "size xs|sm|base|lg; inputSide right|top",
      "Content": "children,className,align,alignOffset,side,sideOffset,container",
      "TriggerInput": "Base UI Input props,clearLabel,showOptionsLabel",
      "TriggerMultipleWithInput": "placeholder,renderItem,className,inputSide,value",
      "compound": "TriggerValue,Chip,Item,Input,Empty,GroupLabel,Group,List,Collection,Trigger,Value,Icon,useFilter"
    },
    "defaults": {
      "size": "base",
      "inputSide": "right",
      "clearLabel": "Clear selection",
      "showOptionsLabel": "Show options",
      "chipRemoveLabel": "Remove",
      "portalContainer": "KumoPortalProvider container or document.body"
    }
  },
  "semantics": {
    "root": "input",
    "aria": [
      "input has combobox semantics and controls popup listbox",
      "items expose option selection/highlight/disabled state",
      "clear,show-options,and chip-remove controls have configurable accessible labels",
      "Field supplies label,required,description,error associations"
    ]
  },
  "initialState": {
    "selection": "value/defaultValue according to Base UI controlled mode",
    "open": "closed unless controlled/default-open",
    "multiple": "false unless set",
    "inputSide": "right"
  },
  "transitions": [
    {
      "action": "type in trigger input",
      "effect": "filters items and opens popup"
    },
    {
      "action": "ArrowDown/ArrowUp",
      "effect": "moves option highlight"
    },
    {
      "action": "Enter/click option",
      "effect": "selects constrained item; multiple mode toggles/chips selection"
    },
    {
      "action": "click clear/remove",
      "effect": "clears selection or removes chip"
    },
    {
      "action": "Escape",
      "effect": "closes popup"
    }
  ],
  "keyboardFocus": {
    "focusable": true,
    "keys": [
      "ArrowDown",
      "ArrowUp",
      "Enter",
      "Escape",
      "Home",
      "End",
      "Backspace"
    ]
  },
  "ssrHydration": {
    "ssr": "supported",
    "hydration": "identical"
  },
