      "effect": "opens modal portal and moves focus into content"
    },
    {
      "action": "click Close",
      "effect": "closes and restores focus to Trigger"
    },
    {
      "action": "Escape",
      "effect": "closes standard dialog and restores focus; alert-dialog dismissal follows AlertDialog primitive"
    },
    {
      "action": "outside press",
      "effect": "dismisses role=dialog; role=alertdialog requires explicit acknowledgement"
    }
  ],
