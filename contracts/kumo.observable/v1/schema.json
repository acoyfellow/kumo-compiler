{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kumo.observable/v1",
  "title": "Kumo observable component contract v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "component",
    "canonical",
    "publicApi",
    "semantics",
    "initialState",
    "transitions",
    "keyboardFocus",
    "ssrHydration",
    "stylingAssets",
    "vectors",
    "unknowns"
  ],
  "properties": {
    "schemaVersion": {
      "const": "kumo.observable/v1"
    },
    "component": {
      "type": "string",
      "pattern": "^[a-z][a-z-]*$"
    },
    "canonical": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "version",
        "exportPath",
        "typesPath",
        "runtimePath",
        "typesSha256",
        "runtimeSha256",
        "irSchemaVersion"
      ],
      "properties": {
        "package": {
          "const": "@cloudflare/kumo"
        },
        "version": {
          "const": "2.5.2"
        },
        "exportPath": {
          "type": "string"
        },
        "typesPath": {
          "type": "string"
        },
        "runtimePath": {
          "type": "string"
        },
        "typesSha256": {
          "$ref": "#/$defs/hash"
        },
        "runtimeSha256": {
          "$ref": "#/$defs/hash"
        },
        "irSchemaVersion": {
          "const": "kumo.ir/v1"
        }
      }
    },
    "publicApi": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "exports",
        "props",
        "defaults"
      ],
      "properties": {
        "exports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "props": {
          "type": "object"
        },
        "defaults": {
          "type": "object"
        }
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root",
        "aria"
      ],
      "properties": {
        "root": {
          "type": "string"
        },
        "aria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "initialState": {
      "type": "object"
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "action",
          "effect"
        ],
        "properties": {
          "action": {
            "type": "string"
          },
          "effect": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "keyboardFocus": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "focusable",
        "keys"
      ],
      "properties": {
        "focusable": {
          "type": "boolean"
        },
        "keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ssrHydration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ssr",
        "hydration"
      ],
      "properties": {
        "ssr": {
          "enum": [
            "supported",
            "unknown",
            "blocked"
          ]
        },
        "hydration": {
          "enum": [
            "identical",
            "unknown",
            "blocked"
          ]
        }
      }
    },
    "stylingAssets": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "classes",
        "assets"
      ],
      "properties": {
        "classes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "vectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "props",
          "expected"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "props": {
            "type": "object"
          },
          "fixture": {
            "oneOf": [
              {
                "$ref": "#/$defs/compositionNode"
              },
              {
                "$ref": "#/$defs/nativeFixture"
              }
            ]
          },
          "setup": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mode",
              "callback"
            ],
            "properties": {
              "mode": {
                "enum": [
                  "controlled"
                ]
              },
              "callback": {
                "enum": [
                  "checked",
                  "value"
                ]
              }
            }
          },
          "actions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "type"
              ],
              "properties": {
                "type": {
                  "enum": [
                    "click",
                    "key",
                    "type",
                    "focus",
                    "blur",
                    "wait"
                  ]
                },
                "key": {
                  "type": "string"
                },
                "text": {
                  "type": "string"
                },
                "editMode": {
                  "enum": ["append", "replace"]
                },
                "scope": {
                  "enum": ["vector", "document"]
                },
                "ms": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 5000
                },
                "selector": {
                  "type": "string",
                  "pattern": "^(?:[a-z][a-z0-9-]*|\\.[A-Za-z_-][\\w-]*|#[A-Za-z_-][\\w-]*|\\[[a-z][a-z0-9-]*(?:=(?:[A-Za-z0-9_-]+|\\\"[^\\\"]+\\\"))?\\])$"
                },
                "target": {
                  "type": "integer",
                  "minimum": 0
                },
                "checkpoint": {
                  "$ref": "#/$defs/expectation"
                }
              }
            }
          },
          "expected": {
            "$ref": "#/$defs/expectation"
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "field",
          "status",
          "reason"
        ],
        "properties": {
          "field": {
            "type": "string"
          },
          "status": {
            "enum": [
              "unknown",
              "blocked"
            ]
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "attributes": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "exact": {
          "$ref": "#/$defs/stringMap"
        },
        "includes": {
          "$ref": "#/$defs/stringMap"
        }
      }
    },
    "classes": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "exact": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "includes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tag": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "attributes": {
          "$ref": "#/$defs/attributes"
        },
        "classes": {
          "$ref": "#/$defs/classes"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "descendant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "count"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "pattern": "^(?:[a-z][a-z0-9-]*|\\.[A-Za-z_-][\\w-]*|#[A-Za-z_-][\\w-]*|\\[[a-z][a-z0-9-]*(?:=(?:[A-Za-z0-9_-]+|\\\"[^\\\"]+\\\"))?\\])$"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "tag": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "attributes": {
          "$ref": "#/$defs/attributes"
        },
        "classes": {
          "$ref": "#/$defs/classes"
        },
        "text": {
          "type": "string"
        }
      }
    },
    "expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "root"
      ],
      "properties": {
        "root": {
          "$ref": "#/$defs/node"
        },
        "descendants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/descendant"
          }
        },
        "state": {
          "type": "object"
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "focus": {
          "type": "string"
        }
      }
    },
    "propValue": {
      "oneOf": [
        {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/propValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/propValue"
          }
        }
      ]
    },
    "textNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        }
      }
    },
    "compositionNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "export",
        "props",
        "children"
      ],
      "properties": {
        "export": {
          "type": "string",
          "pattern": "^(?:root|(?:\\.[A-Za-z_$][\\w$]*)+)$"
        },
        "props": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/propValue"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "$ref": "#/$defs/compositionNode"
              },
              {
                "$ref": "#/$defs/textNode"
              }
            ]
          }
        }
      }
    },
    "nativeFixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "legend",
        "items"
      ],
      "properties": {
        "kind": {
          "enum": [
            "checkbox-group",
            "switch-group",
            "radio-group"
          ]
        },
        "legend": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "disabled": {
                "type": "boolean"
              }
            }
          }
        },
        "defaultValue": {
          "$ref": "#/$defs/propValue"
        },
        "value": {
          "$ref": "#/$defs/propValue"
        },
        "disabled": {
          "type": "boolean"
        }
      }
    }
  }
}
