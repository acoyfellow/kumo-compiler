{
  "name": "kumo-compiler-proof",
  "main": "worker.mjs",
  "compatibility_date": "2026-06-20",
  "workers_dev": false,
  "assets": {
    "directory": "./deploy",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none"
  },
  "vars": {
    "WORKER_VERSION": "2026.06.20",
    "GIT_COMMIT": "set-by-scripts-deploy"
  }
}
