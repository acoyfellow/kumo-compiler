{
  "family": "form",
  "members": ["field", "input", "input-group", "input-area", "sensitive-input", "clipboard-text"],
  "targets": ["react", "vue", "svelte", "solid"],
  "policy": {
    "rendering": ["ssr", "hydrate"],
    "keyboard": ["Tab", "Enter"],
    "clipboard": "navigator.clipboard.writeText with execCommand fallback",
    "labels": "explicit",
    "sensitiveToggle": "button with aria-pressed"
  }
}
