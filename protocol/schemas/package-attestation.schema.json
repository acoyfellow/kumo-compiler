{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kumo.dev/schemas/package-attestation.schema.json",
  "title": "Kumo package attestation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "framework", "package", "inventory", "deterministicPackSha256", "checks", "prerequisites", "status"],
  "properties": {
    "schemaVersion": { "const": "kumo.package-attestation/v1" },
    "framework": { "enum": ["vue", "svelte", "solid"] },
    "package": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "version", "tarballSha256"],
      "properties": {
        "name": { "enum": ["@acoyfellow/kumo-vue", "@acoyfellow/kumo-svelte", "@acoyfellow/kumo-solid"] },
        "version": { "const": "0.0.1" },
        "tarballSha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "inventory": {
      "type": "object", "additionalProperties": false,
      "required": ["manifestCount", "exportCount", "typeCount", "componentCount"],
      "properties": {
        "manifestCount": { "type": "integer", "minimum": 1 },
        "exportCount": { "type": "integer", "minimum": 1 },
        "typeCount": { "type": "integer", "minimum": 1 },
        "componentCount": { "const": 41 }
      }
    },
    "deterministicPackSha256": { "type": "array", "minItems": 2, "maxItems": 2, "items": { "$ref": "#/$defs/sha256" } },
    "checks": {
      "type": "object", "additionalProperties": false,
      "required": ["freshConsumerInstall", "clientBuild", "ssrBuild"],
      "properties": {
        "freshConsumerInstall": { "$ref": "#/$defs/passedCheck" },
        "clientBuild": { "$ref": "#/$defs/passedCheck" },
        "ssrBuild": { "$ref": "#/$defs/passedCheck" }
      }
    },
    "prerequisites": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/prerequisite" } },
    "status": { "const": "passed" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "passedCheck": {
      "type": "object", "additionalProperties": false, "required": ["status", "checkedAt"],
      "properties": { "status": { "const": "passed" }, "checkedAt": { "type": "string", "format": "date-time" } }
    },
    "prerequisite": {
      "type": "object", "additionalProperties": false, "required": ["identity", "sha256"],
      "properties": { "identity": { "type": "string", "minLength": 1 }, "sha256": { "$ref": "#/$defs/sha256" } }
    }
  }
}
