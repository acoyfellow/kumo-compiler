{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kumo.immutable-receipt/v1",
  "title": "Kumo immutable receipt",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "identity", "status", "contentSha256", "prerequisites"],
  "properties": {
    "schemaVersion": { "const": "kumo.immutable-receipt/v1" },
    "identity": { "type": "string", "minLength": 1 },
    "status": { "enum": ["passed", "failed", "blocked", "not-run"] },
    "contentSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["identity", "sha256"],
        "properties": {
          "identity": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    }
  }
}
