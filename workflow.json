{
  "version": 1,
  "steps": [
    {
      "id": "build-runtimes",
      "command": "npm run build:runtimes"
    },
    {
      "id": "build-catalog",
      "command": "npm run catalog:build",
      "dependsOn": ["build-runtimes"]
    },
    {
      "id": "validate-catalog",
      "command": "npm run catalog:validate",
      "dependsOn": ["build-catalog"]
    }
  ]
}
