{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kumo.core-ir/v2",
  "type": "object",
  "required": ["schemaVersion", "authority", "components"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": "kumo.core-ir/v2"},
    "authority": {"type": "object", "required": ["package", "version", "inputs"]},
    "components": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "states", "viewports", "parts", "behavior", "accessibility", "provenance"],
        "properties": {
          "name": {"type": "string"},
          "states": {"type": "object", "required": ["initial", "values", "observations"]},
          "viewports": {"type": "array", "items": {"type": "number"}},
          "parts": {"type": "array", "items": {"type": "object", "required": ["id", "parent", "samples"]}},
          "behavior": {"type": "array"},
          "accessibility": {"type": "array"},
          "provenance": {"type": "object", "required": ["source", "frontendFacts", "traces"]}
        },
        "additionalProperties": false
      }
    }
  }
}
