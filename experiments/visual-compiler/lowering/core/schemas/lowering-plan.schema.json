{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kumo.lowering-plan/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "algorithm", "manifestDigest", "shards"],
  "properties": {
    "schemaVersion": { "const": "kumo.lowering-plan/v1" },
    "algorithm": { "const": "sha256" },
    "manifestDigest": { "$ref": "#/$defs/digest" },
    "shards": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/shard" } }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "operation": {
      "type": "object",
      "required": ["kind", "part"],
      "properties": {
        "kind": { "enum": ["node.create", "node.text", "state.init", "state.transition", "portal.mount", "portal.unmount", "attribute.set", "attribute.remove", "class.add", "class.remove", "event.listen"] },
        "part": { "type": ["string", "null"] },
        "when": { "type": ["object", "array", "string", "boolean", "null"] }
      }
    },
    "shard": {
      "type": "object",
      "required": ["key", "contentDigest", "shard", "initialState", "states", "inputs", "operations", "provenance"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "contentDigest": { "$ref": "#/$defs/digest" },
        "shard": { "type": "string", "pattern": "^sha256-[a-f0-9]{64}\\.json$" },
        "initialState": { "type": "string" },
        "states": { "type": "array", "minItems": 1, "items": { "type": "string" }, "uniqueItems": true },
        "inputs": { "type": "object" },
        "operations": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/operation" } },
        "provenance": { "type": "object" }
      }
    }
  }
}
