{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Kumo production proof",
  "type": "object",
  "required": ["hostname", "workerVersion", "gitCommit", "manifestHash", "timestamp", "routes", "access"],
  "properties": {
    "hostname": { "type": "string", "minLength": 1 },
    "workerVersion": { "type": "string", "minLength": 1 },
    "gitCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "manifestHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "timestamp": { "type": "string", "format": "date-time" },
    "routes": { "type": "array", "minItems": 1, "items": { "type": "object", "required": ["id", "status", "ok"] } },
    "access": { "type": "object", "required": ["deniedStatus", "allowedStatus", "logCorrelationIds"], "properties": { "deniedStatus": { "enum": [302, 401, 403] }, "allowedStatus": { "type": "integer", "minimum": 200, "maximum": 299 }, "logCorrelationIds": { "type": "array", "minItems": 1, "items": { "type": "string" } } } }
  },
  "additionalProperties": false
}
