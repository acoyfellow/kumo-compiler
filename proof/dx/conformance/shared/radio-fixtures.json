  "plans": [
    {
      "schemaVersion": "kumo.fixture-plan/v1",
      "component": "radio",
      "vector": "default-click",
      "contract": {
        "schemaVersion": "kumo.observable/v1",
        "path": "contracts/kumo.observable/v1/components/radio.json",
        "sha256": "9c7f5e00c6ff6b1e706de5cd52823bb4e7642f4b9c69a4bca97728165fd3057a",
        "vectorSha256": "d82c31a3a4003d5d1e8c593323b3efe94c77f49c3ccb3c407e82b273c74b275b"
      },
      "fixture": {
        "kind": "family-fixture",
        "family": "radio-group",
        "adapterRequirement": "radio-group-adapter",
        "payload": {
          "kind": "radio-group",
          "legend": "Plan",
          "items": [
            {
              "label": "Free",
              "value": "free"
            },
            {
              "label": "Pro",
              "value": "pro"
            }
          ],
          "defaultValue": "free"
        }
      },
      "setup": [
        {
          "kind": "uncontrolled-state",
          "mode": "uncontrolled",
          "initial": "free"
        },
        {
          "kind": "event-recorder"
        }
      ],
      "actions": [
        {
          "type": "click",
          "target": 1
        }
      ],
      "probes": [
        {
          "kind": "dom",
          "path": "root"
        },
        {
          "kind": "state",
          "path": "state"
        },
        {
          "kind": "events",
          "path": "events"
        },
        {
          "kind": "focus",
          "path": "focus"
        },
        {
          "kind": "node-identity",
          "path": "root"
        }
      ],
      "assertions": [
        {
          "kind": "includes",
          "probe": "dom",
          "expected": {
            "tag": "div",
            "attributes": {
              "includes": {
                "role": "radiogroup"
              }
            }
          }
        },
        {
          "kind": "equals",
          "probe": "state",
          "expected": {
            "checked": [
              false,
              true
            ]
          }
        },
        {
          "kind": "sequence",
          "probe": "events",
          "expected": [
            "value:pro"
          ]
        },
        {
          "kind": "equals",
          "probe": "focus",
          "expected": "root"
        },
        {
          "kind": "identity",
          "probe": "node-identity",
          "expected": "preserved"
        }
      ],
      "capabilities": [
        "radio-fixture",
        "radio-group-adapter",
        "trusted-actions",
        "dom-probes",
        "state-probes",
        "event-probes",
        "focus-probes",
