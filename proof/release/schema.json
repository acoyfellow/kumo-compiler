{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kumo-compiler.coey.dev/proof/release/schema.json",
  "title": "Kumo deterministic double-release receipt",
  "type": "object",
  "required": ["schemaVersion", "status", "commit", "runMode", "command", "environment", "independentRuns", "observation", "publication", "receiptSha256"],
  "properties": {
    "schemaVersion": { "const": "kumo.release-twice/v1" },
    "status": { "const": "passed" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "runMode": { "type": "string", "minLength": 1 },
    "command": { "const": "npm run release:check" },
    "environment": {
      "type": "object",
      "required": ["node", "npm"],
      "properties": { "node": { "type": "string" }, "npm": { "type": "string" } },
      "additionalProperties": false
    },
    "independentRuns": { "const": 2 },
    "observation": {
      "type": "object",
      "required": ["packages", "githubReleaseAssets", "deployManifestSourceSha256", "deployPayloadSha256"],
      "properties": {
        "packages": { "$ref": "#/$defs/artifacts", "minItems": 3, "maxItems": 3 },
        "githubReleaseAssets": { "$ref": "#/$defs/artifacts" },
        "deployManifestSourceSha256": { "$ref": "#/$defs/sha256" },
        "deployPayloadSha256": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "publication": {
      "type": "object",
      "required": ["npm", "github", "deploy", "gitPush"],
      "properties": {
        "npm": { "const": false }, "github": { "const": false },
        "deploy": { "const": false }, "gitPush": { "const": false }
      },
      "additionalProperties": false
    },
    "receiptSha256": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "artifacts": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["file", "sha256"],
        "properties": { "file": { "type": "string", "minLength": 1 }, "sha256": { "$ref": "#/$defs/sha256" } },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
