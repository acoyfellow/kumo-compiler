{
  "name": "@cloudflare/kumo-svelte",
  "version": "0.0.0-consumer-dx-pilot",
  "private": true,
  "type": "module",
  "sideEffects": [
    "*.css",
    "./dist/*.css"
  ],
  "exports": {
    ".": {
      "types": "./package/index.d.ts",
      "import": "./package/index.js"
    },
    "./button": {
      "types": "./package/index.d.ts",
      "import": "./package/index.js"
    },
    "./field": {
      "types": "./package/index.d.ts",
      "import": "./package/index.js"
    },
    "./tabs": {
      "types": "./package/index.d.ts",
      "import": "./package/index.js"
    },
    "./styles.css": "./package/styles.css",
    "./tokens.css": "./package/tokens.css",
    "./manifest": "./kumo.manifest.json"
  },
  "files": [
    "package",
    "kumo.manifest.json"
  ],
  "main": "./package/index.js",
  "types": "./package/index.d.ts"
}
